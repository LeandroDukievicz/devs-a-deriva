---
import { readFileSync } from 'fs';
import { resolve } from 'path';

const logoRaw = readFileSync(resolve('./public/logohelmet.svg'), 'utf-8');
const logoForCanvas = Buffer.from(
  logoRaw
    .replace(/<\?xml[^?]*\?>\s*/g, '')
    .replace(/<!DOCTYPE[^>]*>\s*/g, '')
    .replace(/fill="#000000"/g, 'fill="white"')
).toString('base64');
---

<a
  id="nav-logo-link"
  href="/"
  class="nav-logo-link"
  aria-label="Ir para a home"
>
  <canvas
    id="nav-logo-canvas"
    width="198"
    height="198"
    data-logo-svg={`data:image/svg+xml;base64,${logoForCanvas}`}
    class="nav-logo-canvas"
  ></canvas>
</a>

<nav class="navbar">
  <ul class="nav-links">
    <li>
        <a href="/" class="nav-link nav-link--home">
          <span class="nav-home-icon" aria-hidden="true">
            <span class="nav-prefix nav-home-prefix">&gt;_</span>
            <canvas class="globe-canvas" aria-hidden="true"></canvas>
          </span>Home
        </a>
      </li>
    <li class="has-dropdown">
      <button class="nav-link nav-btn nav-link--categorias" id="cat-btn" aria-expanded="false" aria-controls="cat-menu">
        <span class="nav-icon-wrap nav-categorias-icon" aria-hidden="true">
          <span class="nav-prefix nav-categorias-prefix">&gt;_</span>
          <canvas class="categorias-canvas" aria-hidden="true"></canvas>
        </span>Categorias
      </button>
      <ul class="dropdown" id="cat-menu" role="menu">
        <li role="none"><a href="/categorias/aleatoriedades"    class="dropdown-link" role="menuitem">Aleatoriedades</a></li>
        <li role="none"><a href="/categorias/carreira"         class="dropdown-link" role="menuitem">Carreira Profissional</a></li>
        <li role="none"><a href="/categorias/livros"           class="dropdown-link" role="menuitem">Livros &amp; Leituras</a></li>
        <li role="none"><a href="/categorias/musica"           class="dropdown-link" role="menuitem">Música</a></li>
        <li role="none"><a href="/categorias/noticias"         class="dropdown-link" role="menuitem">Notícias</a></li>
        <li role="none"><a href="/categorias/tech"             class="dropdown-link" role="menuitem">Tech</a></li>
      </ul>
    </li>
    <li><a href="/devs" class="nav-link nav-link--devs">
      <span class="nav-icon-wrap nav-devs-icon" aria-hidden="true">
        <span class="nav-prefix nav-devs-prefix">&gt;_</span>
        <canvas class="devs-canvas" aria-hidden="true"></canvas>
      </span>Devs</a></li>
    <li><a href="/manifesto" class="nav-link nav-link--manifesto">
      <span class="nav-icon-wrap nav-manifesto-icon" aria-hidden="true">
        <span class="nav-prefix nav-manifesto-prefix">&gt;_</span>
        <canvas class="manifesto-canvas" aria-hidden="true"></canvas>
      </span>Manifesto</a></li>
    <li class="has-dropdown">
      <button class="nav-link nav-btn nav-link--temas" id="temas-btn" aria-expanded="false" aria-controls="temas-menu">
        <span class="nav-icon-wrap nav-temas-icon" aria-hidden="true">
          <span class="nav-prefix nav-temas-prefix">&gt;_</span>
          <canvas class="temas-canvas" aria-hidden="true"></canvas>
        </span>Temas
      </button>
      <ul class="dropdown" id="temas-menu" role="menu">
        <li role="none"><button class="dropdown-link dropdown-btn" data-theme="orbita-baixa">Órbita Baixa</button></li>
        <li role="none"><button class="dropdown-link dropdown-btn" data-theme="espaco-profundo">Espaço Profundo</button></li>
        <li role="none"><button class="dropdown-link dropdown-btn" data-theme="limbo">Limbo</button></li>
      </ul>
    </li>
  </ul>
</nav>

<div id="theme-modal" class="modal-overlay" aria-hidden="true">
  <div class="modal-box" role="dialog" aria-modal="true">
    <svg class="modal-warn" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
      <line x1="12" y1="9" x2="12" y2="13"/>
      <line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
    <div id="modal-default-content">
      <p class="modal-question"><span class="nav-prefix">&gt;_</span> Você tem certeza que deseja mudar pra este tema?</p>
      <div class="modal-actions">
        <button id="modal-confirm" class="modal-btn modal-btn--confirm">Confirmar</button>
        <button id="modal-cancel"  class="modal-btn modal-btn--cancel">Cancelar</button>
      </div>
    </div>
    <p id="modal-bye" class="modal-bye" aria-hidden="true">Bom, eu avisei!</p>
  </div>
</div>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 32px;
    height: 52px;
    overflow: visible;
    background: transparent;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-10px);
    box-shadow: none;
    backdrop-filter: blur(0);
    -webkit-backdrop-filter: blur(0);
    transition:
      opacity 0.45s ease,
      transform 0.45s ease,
      visibility 0.45s ease,
      background-color 0.28s ease,
      box-shadow 0.28s ease,
      backdrop-filter 0.28s ease;
  }

  .navbar.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .navbar.is-scrolled {
    background: var(--color-bg-88);
    box-shadow: 0 10px 28px rgb(0 0 0 / 0.24);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .nav-logo-link {
    position: fixed;
    top: -50px;
    left: -50px;
    z-index: 101;
    display: block;
    width: 198px;
    height: 198px;
    flex-shrink: 0;
    text-decoration: none;
    outline: none;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.45s ease, transform 0.35s ease;
  }

  .nav-logo-link.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .nav-logo-canvas {
    display: block;
    width: 198px;
    height: 198px;
    transition: filter 0.35s ease, transform 0.35s ease;
  }

  .nav-logo-link:hover .nav-logo-canvas,
  .nav-logo-link:focus-visible .nav-logo-canvas {
    animation: logo-cyberpunk 2.2s linear infinite, logo-pulse 1.4s ease-in-out infinite;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0;
    font-family: monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-star);
    text-decoration: none;
    animation: nav-pulse 3s ease-in-out infinite;
    transition: color 0.22s ease, text-shadow 0.22s ease;
  }

  .nav-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  li:nth-child(1) .nav-link { animation-delay: 0s; }
  li:nth-child(2) .nav-link { animation-delay: 0.4s; }
  li:nth-child(3) .nav-link { animation-delay: 0.8s; }
  li:nth-child(4) .nav-link { animation-delay: 1.2s; }
  li:nth-child(5) .nav-link { animation-delay: 1.6s; }

  @keyframes nav-pulse {
    0%, 100% { text-shadow: 0 0 6px var(--color-star-40); opacity: 1; }
    50%       { text-shadow: 0 0 14px var(--color-star-90); opacity: 0.75; }
  }

  @keyframes logo-cyberpunk {
    0% {
      filter: hue-rotate(0deg) saturate(1) brightness(1);
    }
    33% {
      filter: hue-rotate(24deg) saturate(1.35) brightness(1.08);
    }
    66% {
      filter: hue-rotate(-18deg) saturate(1.45) brightness(1.02);
    }
    100% {
      filter: hue-rotate(0deg) saturate(1) brightness(1);
    }
  }

  @keyframes logo-pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.045);
    }
  }

  .nav-prefix {
    color: var(--color-star);
    transition: color 0.22s ease;
    margin-right: 1px;
  }

  .nav-link:hover {
    color: var(--color-accent);
    animation: none;
    text-shadow: 0 0 12px var(--color-accent-60);
  }

  .nav-link:hover .nav-prefix {
    color: var(--color-accent);
  }

  .admin-link {
    gap: 6px;
  }

  .admin-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 68px;
    height: 68px;
    flex-shrink: 0;
    color: var(--color-star);
    transition: transform 0.22s ease;
  }

  :global(.admin-icon svg) {
    display: block;
    width: 68px;
    height: 68px;
  }

  :global(.admin-icon #antenna-left) {
    fill: var(--color-star);
    transform-box: fill-box;
    transform-origin: center;
    transition: fill 0.22s ease, filter 0.22s ease;
  }

  .admin-link:hover .admin-icon,
  .admin-link:focus-visible .admin-icon {
    transform: translateY(-1px);
  }

  .admin-link:hover :global(.admin-icon #antenna-left),
  .admin-link:focus-visible :global(.admin-icon #antenna-left) {
    animation: gear-spin 3s linear infinite;
    fill: var(--color-accent);
    filter: drop-shadow(0 0 8px var(--color-accent-40));
  }

  @keyframes gear-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Dropdown */
  .has-dropdown {
    position: relative;
  }

  .dropdown {
    list-style: none;
    margin: 0;
    padding: 8px 0;
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 180px;
    background: var(--color-bg-88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-star-18);
    border-radius: 6px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
  }

  .dropdown.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    padding: 8px 18px;
    font-family: monospace;
    font-size: 0.59rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-star);
    text-decoration: none;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .dropdown-link:hover {
    color: var(--color-accent);
    background: var(--color-accent-06);
  }

  .dropdown-link:hover .nav-prefix {
    color: var(--color-accent);
  }

  .dropdown-btn {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  /* Limbo theme overrides (text handled globally by ThemeProvider) */
  :global(html[data-theme="limbo"]) .dropdown {
    background: rgba(255, 255, 255, 0.95) !important;
    border-color: rgba(0, 0, 0, 0.15) !important;
  }

  :global(html[data-theme="limbo"]) .dropdown-link:hover {
    background: rgba(0, 0, 0, 0.06) !important;
  }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-70);
    backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.22s ease, visibility 0.22s ease;
  }

  .modal-overlay.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .modal-box {
    background: var(--color-bg-95);
    border: 1px solid var(--color-star-25);
    border-radius: 8px;
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 360px;
    width: 90%;
    transform: translateY(8px);
    transition: transform 0.22s ease;
  }

  .modal-overlay.is-open .modal-box {
    transform: translateY(0);
  }

  .modal-warn {
    width: 36px;
    height: 36px;
    color: #ff2a2a;
    align-self: center;
    filter: drop-shadow(0 0 6px rgba(255, 42, 42, 0.7));
    animation: warn-pulse 1s ease-in-out infinite;
  }

  @keyframes warn-pulse {
    0%, 100% { opacity: 1;   filter: drop-shadow(0 0 6px rgba(255, 42, 42, 0.7)); }
    50%       { opacity: 0.3; filter: drop-shadow(0 0 2px rgba(255, 42, 42, 0.2)); }
  }

  .modal-question {
    margin: 0;
    font-family: monospace;
    font-size: 0.78rem;
    color: var(--color-star);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.6;
  }

  .modal-actions {
    display: flex;
    gap: 20px;
    justify-content: flex-end;
    margin-top: 8px;
  }

  .modal-btn {
    font-family: monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 10px 28px;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }

  .modal-btn--confirm {
    background: transparent;
    border: 1px outset var(--color-star);
    color: var(--color-star);
  }

  .modal-btn--confirm:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-08);
    box-shadow: 0 0 12px var(--color-accent-20);
  }

  .modal-btn--cancel {
    background: transparent;
    border: 1px solid var(--color-star-22);
    color: #5a8a94;
  }

  .modal-btn--cancel:hover {
    border-color: var(--color-star-40);
    color: #a0c4cc;
  }

  .modal-bye {
    display: none;
    font-family: monospace;
    font-size: 1rem;
    font-weight: bold;
    color: #ff2a2a;
    text-align: center;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    animation: warn-pulse 0.8s ease-in-out infinite;
  }

  /* ── Icon hover shared ──────────────────────────────────────── */
  .nav-home-icon,
  .nav-icon-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 22px;
    width: 22px;
    height: 22px;
    margin-right: 5px;
  }

  .nav-home-prefix,
  .nav-categorias-prefix,
  .nav-devs-prefix,
  .nav-manifesto-prefix,
  .nav-temas-prefix {
    transition: opacity 0.2s ease;
    margin-right: 0;
  }

  .globe-canvas,
  .categorias-canvas,
  .devs-canvas,
  .manifesto-canvas,
  .temas-canvas {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 22px;
    height: 22px;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .nav-link--home:hover .nav-home-prefix         { opacity: 0; }
  .nav-link--home:hover .globe-canvas            { opacity: 1; }

  .nav-link--categorias:hover .nav-categorias-prefix { opacity: 0; }
  .nav-link--categorias:hover .categorias-canvas     { opacity: 1; }

  .nav-link--devs:hover .nav-devs-prefix     { opacity: 0; }
  .nav-link--devs:hover .devs-canvas         { opacity: 1; }

  .nav-link--manifesto:hover .nav-manifesto-prefix { opacity: 0; }
  .nav-link--manifesto:hover .manifesto-canvas     { opacity: 1; }

  .nav-link--temas:hover .nav-temas-prefix { opacity: 0; }
  .nav-link--temas:hover .temas-canvas     { opacity: 1; }

  @media (max-width: 480px) {
    .navbar {
      top: 12px;
      left: 12px;
      right: 12px;
      height: auto;
      padding: 12px 14px;
      border: 1px solid var(--color-star-18);
      border-radius: 14px;
      background: var(--color-bg-88);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }

    .nav-links {
      width: 100%;
      justify-content: space-between;
      flex-wrap: nowrap;
      gap: 0;
    }

    .nav-logo-link {
      display: none;
    }

    .nav-link {
      font-size: 0.56rem;
      letter-spacing: 0.06em;
      white-space: nowrap;
    }

    .nav-links > li {
      flex: 1 1 0;
      display: flex;
      justify-content: center;
      min-width: 0;
    }

    .nav-links > li > .nav-link,
    .nav-links > li > .nav-btn {
      width: 100%;
      justify-content: center;
    }

    .nav-home-icon,
    .nav-icon-wrap {
      flex-basis: 18px;
      width: 18px;
      height: 18px;
      margin-right: 4px;
    }

    .globe-canvas,
    .categorias-canvas,
    .devs-canvas,
    .manifesto-canvas,
    .temas-canvas {
      width: 18px;
      height: 18px;
    }

    .has-dropdown {
      position: static;
    }

    .dropdown {
      top: calc(100% + 12px);
      left: 50%;
      transform: translateX(-50%) translateY(-6px);
      width: min(92vw, 260px);
      min-width: 0;
      max-width: calc(100vw - 24px);
    }

    .dropdown.is-open {
      transform: translateX(-50%) translateY(0);
    }

    .dropdown-link {
      padding: 10px 16px;
      font-size: 0.62rem;
      white-space: normal;
      line-height: 1.45;
    }
  }

  @media (max-width: 300px) {
    .navbar {
      left: 8px;
      right: 8px;
      padding: 10px 8px;
    }

    .nav-links {
      flex-wrap: wrap;
      justify-content: center;
      row-gap: 8px;
      column-gap: 10px;
    }

    .nav-links > li {
      flex: 0 1 auto;
    }

    .nav-links > li > .nav-link,
    .nav-links > li > .nav-btn {
      width: auto;
    }

    .nav-link {
      font-size: 0.52rem;
      letter-spacing: 0.04em;
    }

    .nav-home-icon,
    .nav-icon-wrap {
      flex-basis: 16px;
      width: 16px;
      height: 16px;
      margin-right: 3px;
    }

    .globe-canvas,
    .categorias-canvas,
    .devs-canvas,
    .manifesto-canvas,
    .temas-canvas {
      width: 16px;
      height: 16px;
    }

    .dropdown {
      width: min(calc(100vw - 16px), 240px);
      max-width: calc(100vw - 16px);
    }
  }
</style>

<script>
  import { applyTheme, themes, type ThemeKey } from '../lib/themes';

  const navWindow = window as typeof window & {
    __ddaNavbarAbort?: AbortController;
    __applyDdaTheme?: (theme: string) => boolean;
  };
  navWindow.__ddaNavbarAbort?.abort();
  const navAbort = new AbortController();
  navWindow.__ddaNavbarAbort = navAbort;
  const navSignal = navAbort.signal;

  // ── Navbar visibility ────────────────────────────────────────────
  // On the home page (/), the BlackHole animation fires 'animationComplete'
  // to reveal the navbar. On every other page we show it immediately.
  const INTRO_KEY = 'intro_last_shown';
  const TODAY     = new Date().toISOString().slice(0, 10);
  const navbar    = document.querySelector('.navbar') as HTMLElement | null;
  const logoLink = document.getElementById('nav-logo-link') as HTMLAnchorElement | null;
  const logoCanvas = document.getElementById('nav-logo-canvas') as HTMLCanvasElement | null;
  const logoCtx = logoCanvas?.getContext('2d') ?? null;

  function showNavbar() {
    navbar?.classList.add('is-visible');
    logoLink?.classList.add('is-visible');
  }

  function syncScrolledNavbar() {
    navbar?.classList.toggle('is-scrolled', window.scrollY > 8);
  }

  syncScrolledNavbar();
  window.addEventListener('scroll', syncScrolledNavbar, { passive: true, signal: navSignal });

  if (logoCanvas && logoCtx) {
    const css = getComputedStyle(document.documentElement);
    const colorStar = css.getPropertyValue('--color-star').trim() || '#00d4e8';
    const colorAccent = css.getPropertyValue('--color-accent').trim() || '#e800d4';
    const logoImage = new Image();
    logoImage.src = logoCanvas.dataset.logoSvg!;

    logoImage.onload = () => {
      const size = logoCanvas.width;
      const iw = logoImage.naturalWidth || 1365;
      const ih = logoImage.naturalHeight || 768;
      const scale = Math.min(size / iw, size / ih);
      const dw = iw * scale;
      const dh = ih * scale;
      const dx = (size - dw) / 2;
      const dy = (size - dh) / 2;

      logoCtx.clearRect(0, 0, size, size);
      logoCtx.drawImage(logoImage, dx, dy, dw, dh);

      const grad = logoCtx.createLinearGradient(0, 0, size, size);
      grad.addColorStop(0, colorStar);
      grad.addColorStop(1, colorAccent);
      logoCtx.globalCompositeOperation = 'source-atop';
      logoCtx.fillStyle = grad;
      logoCtx.fillRect(0, 0, size, size);
      logoCtx.globalCompositeOperation = 'source-over';
    };
  }

  const isHome = window.location.pathname === '/' || window.location.pathname === '';
  if (!isHome || localStorage.getItem(INTRO_KEY) === TODAY) {
    showNavbar();
  } else {
    window.addEventListener('animationComplete', showNavbar, { once: true, signal: navSignal });
  }

  // ── Dropdowns ────────────────────────────────────────────────────
  const dropdowns = [
    { btn: document.getElementById('cat-btn'),   menu: document.getElementById('cat-menu') },
    { btn: document.getElementById('temas-btn'), menu: document.getElementById('temas-menu') },
  ];
  const hoverCloseTimers = new WeakMap<HTMLElement, number>();
  let pinnedMenu: HTMLElement | null = null;

  function isMobileNavbar() {
    return window.matchMedia('(max-width: 480px)').matches;
  }

  function setDropdownState(
    btn: HTMLElement | null,
    menu: HTMLElement | null,
    open: boolean
  ) {
    menu?.classList.toggle('is-open', open);
    btn?.setAttribute('aria-expanded', String(open));
  }

  function closeAll(except?: Element) {
    dropdowns.forEach(({ btn, menu }) => {
      if (menu === except) return;
      setDropdownState(btn as HTMLElement | null, menu as HTMLElement | null, false);
    });
    if (!except || pinnedMenu !== except) pinnedMenu = null;
  }

  function clearHoverClose(menu: HTMLElement | null) {
    if (!menu) return;
    const timer = hoverCloseTimers.get(menu);
    if (timer) {
      window.clearTimeout(timer);
      hoverCloseTimers.delete(menu);
    }
  }

  function scheduleHoverClose(btn: HTMLElement | null, menu: HTMLElement | null) {
    if (!menu) return;
    if (pinnedMenu === menu) return;
    clearHoverClose(menu);
    const timer = window.setTimeout(() => {
      setDropdownState(btn, menu, false);
      hoverCloseTimers.delete(menu);
    }, 160);
    hoverCloseTimers.set(menu, timer);
  }

  dropdowns.forEach(({ btn, menu }) => {
    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      pinnedMenu = menu as HTMLElement | null;
      closeAll(menu!);
      setDropdownState(btn as HTMLElement | null, menu as HTMLElement | null, true);
    }, { signal: navSignal });

    const parent = btn?.closest('.has-dropdown');
    parent?.addEventListener('mouseenter', () => {
      if (isMobileNavbar()) return;
      clearHoverClose(menu as HTMLElement | null);
      closeAll(menu!);
      setDropdownState(btn as HTMLElement | null, menu as HTMLElement | null, true);
    }, { signal: navSignal });

    parent?.addEventListener('mouseleave', () => {
      if (isMobileNavbar()) return;
      scheduleHoverClose(btn as HTMLElement | null, menu as HTMLElement | null);
    }, { signal: navSignal });

    menu?.addEventListener('mouseenter', () => {
      if (isMobileNavbar()) return;
      clearHoverClose(menu as HTMLElement | null);
      setDropdownState(btn as HTMLElement | null, menu as HTMLElement | null, true);
    }, { signal: navSignal });

    menu?.addEventListener('mouseleave', () => {
      if (isMobileNavbar()) return;
      scheduleHoverClose(btn as HTMLElement | null, menu as HTMLElement | null);
    }, { signal: navSignal });

    menu?.addEventListener('click', () => {
      pinnedMenu = null;
    }, { signal: navSignal });
  });

  document.addEventListener('click', (e) => {
    const target = e.target as Element | null;
    if (target?.closest('.has-dropdown')) return;
    closeAll();
  }, { signal: navSignal });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); }, { signal: navSignal });

  // ── Theme modal ───────────────────────────────────────────────────
  const modal              = document.getElementById('theme-modal')!;
  const modalConfirm       = document.getElementById('modal-confirm')!;
  const modalCancel        = document.getElementById('modal-cancel')!;
  const modalDefaultContent = document.getElementById('modal-default-content')!;
  const modalBye           = document.getElementById('modal-bye')!;
  let pendingTheme: ThemeKey | null = null;

  function openModal()  {
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    pendingTheme = null;
  }

  function forceApplyTheme(key: ThemeKey) {
    if (!navWindow.__applyDdaTheme?.(key)) {
      applyTheme(key);
      window.dispatchEvent(new CustomEvent('dda-theme-change', { detail: { theme: key } }));
    }

    // Force the current page to invalidate CSS variable consumers immediately.
    void document.documentElement.offsetHeight;
    requestAnimationFrame(() => {
      if (!navWindow.__applyDdaTheme?.(key)) {
        applyTheme(key);
        window.dispatchEvent(new CustomEvent('dda-theme-change', { detail: { theme: key } }));
      }
    });
  }

  modalConfirm.addEventListener('click', () => {
    if (pendingTheme === 'limbo') {
      modalDefaultContent.style.display = 'none';
      modalBye.style.display = 'block';
      modalBye.setAttribute('aria-hidden', 'false');
      setTimeout(() => {
        forceApplyTheme('limbo');
        closeModal();
        modalDefaultContent.style.display = '';
        modalBye.style.display = 'none';
        modalBye.setAttribute('aria-hidden', 'true');
      }, 1500);
    } else {
      if (pendingTheme) forceApplyTheme(pendingTheme);
      closeModal();
    }
  }, { signal: navSignal });

  modalCancel.addEventListener('click', closeModal, { signal: navSignal });
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); }, { signal: navSignal });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); }, { signal: navSignal });

  // ── Globe (Home hover) ────────────────────────────────────────────
  const homeNavLink = document.querySelector<HTMLAnchorElement>('.nav-link--home');
  const globeCanvas = document.querySelector<HTMLCanvasElement>('.globe-canvas');
  const globeCtx    = globeCanvas?.getContext('2d') ?? null;

  if (homeNavLink && globeCanvas && globeCtx) {
    const DPR  = Math.min(window.devicePixelRatio || 1, 2);
    const SIZE = 22;
    globeCanvas.width  = SIZE * DPR;
    globeCanvas.height = SIZE * DPR;
    globeCtx.scale(DPR, DPR);

    const CX = SIZE / 2;
    const CY = SIZE / 2;
    const R  = SIZE / 2 - 2;

    let globeAngle = 0;
    let globeRAF: number | null = null;

    function toRad(d: number) { return d * Math.PI / 180; }

    function gpt(lat: number, lng: number) {
      const φ = toRad(lat);
      const λ = toRad(lng + globeAngle);
      return {
        x:  Math.cos(φ) * Math.sin(λ),
        y: -Math.sin(φ),
        z:  Math.cos(φ) * Math.cos(λ),
      };
    }

    function drawGlobeFrame() {
      const css   = getComputedStyle(document.documentElement);
      const color = css.getPropertyValue('--color-accent').trim() || '#e800d4';

      globeCtx.clearRect(0, 0, SIZE, SIZE);

      // Sphere outline
      globeCtx.beginPath();
      globeCtx.arc(CX, CY, R, 0, Math.PI * 2);
      globeCtx.strokeStyle = color;
      globeCtx.lineWidth   = 0.7;
      globeCtx.globalAlpha = 0.5;
      globeCtx.stroke();

      // Meridians every 30°
      for (let lng = 0; lng < 360; lng += 30) {
        globeCtx.beginPath();
        let pen = false;
        for (let lat = -90; lat <= 90; lat += 4) {
          const p = gpt(lat, lng);
          if (p.z <= 0.01) { pen = false; continue; }
          const px = CX + p.x * R;
          const py = CY + p.y * R;
          pen ? globeCtx.lineTo(px, py) : globeCtx.moveTo(px, py);
          pen = true;
        }
        globeCtx.strokeStyle = color;
        globeCtx.lineWidth   = 0.45;
        globeCtx.globalAlpha = 0.28;
        globeCtx.stroke();
      }

      // Parallels at -60 -30 0 30 60
      for (const lat of [-60, -30, 0, 30, 60]) {
        globeCtx.beginPath();
        let pen = false;
        for (let lng = 0; lng <= 360; lng += 4) {
          const p = gpt(lat, lng);
          if (p.z <= 0.01) { pen = false; continue; }
          const px = CX + p.x * R;
          const py = CY + p.y * R;
          pen ? globeCtx.lineTo(px, py) : globeCtx.moveTo(px, py);
          pen = true;
        }
        globeCtx.strokeStyle = color;
        globeCtx.lineWidth   = lat === 0 ? 0.65 : 0.45;
        globeCtx.globalAlpha = lat === 0 ? 0.42 : 0.28;
        globeCtx.stroke();
      }

      globeCtx.globalAlpha = 1;
      globeAngle = (globeAngle + 0.45) % 360;
      globeRAF   = requestAnimationFrame(drawGlobeFrame);
    }

    homeNavLink.addEventListener('mouseenter', () => {
      if (!globeRAF) drawGlobeFrame();
    });

    homeNavLink.addEventListener('mouseleave', () => {
      if (globeRAF !== null) { cancelAnimationFrame(globeRAF); globeRAF = null; }
      globeCtx.clearRect(0, 0, SIZE, SIZE);
    });
  }

  // ── Categorias icon (folder opening) ─────────────────────────────
  (function() {
    const link   = document.querySelector<HTMLElement>('.nav-link--categorias');
    const canvas = document.querySelector<HTMLCanvasElement>('.categorias-canvas');
    const ctx    = canvas?.getContext('2d') ?? null;
    if (!link || !canvas || !ctx) return;

    const DPR  = Math.min(window.devicePixelRatio || 1, 2);
    const SIZE = 22;
    canvas.width  = SIZE * DPR;
    canvas.height = SIZE * DPR;
    ctx.scale(DPR, DPR);

    let raf: number | null = null;

    // Folder geometry (total height = tabH + bh = 11px, centered in 22px → top at 5.5)
    const bx = 2, by = 8, bw = 18, bh = 9; // body rect
    const tabW = 7, tabH = 2;               // tab above body

    function draw() {
      const color = getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim() || '#e800d4';
      const t = Date.now() / 900;
      // open oscillates 0→1→0 smoothly
      const open = (1 - Math.cos(t * Math.PI * 2)) / 2;
      const lift = open * 5;

      ctx.clearRect(0, 0, SIZE, SIZE);
      ctx.strokeStyle = color;
      ctx.lineWidth = 1;

      // Folder tab (top-left flap)
      ctx.beginPath();
      ctx.moveTo(bx, by);
      ctx.lineTo(bx, by - tabH);
      ctx.lineTo(bx + tabW, by - tabH);
      ctx.lineTo(bx + tabW + 1.5, by);
      ctx.globalAlpha = 0.8;
      ctx.stroke();

      // Folder body
      ctx.beginPath();
      ctx.rect(bx, by, bw, bh);
      ctx.globalAlpha = 0.8;
      ctx.stroke();

      // Lid — arcs upward from left hinge
      ctx.beginPath();
      ctx.moveTo(bx, by);
      ctx.bezierCurveTo(
        bx + bw * 0.3, by - lift,
        bx + bw * 0.7, by - lift,
        bx + bw, by
      );
      ctx.globalAlpha = 0.7 + 0.3 * open;
      ctx.lineWidth = 1;
      ctx.stroke();

      // Content lines revealed when open
      if (open > 0.25) {
        ctx.lineWidth = 0.65;
        ctx.globalAlpha = 0.55 * open;
        ctx.beginPath();
        ctx.moveTo(bx + 2.5, by + 3);
        ctx.lineTo(bx + bw - 2.5, by + 3);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(bx + 2.5, by + 5.5);
        ctx.lineTo(bx + bw - 5, by + 5.5);
        ctx.stroke();
      }

      ctx.globalAlpha = 1;
      raf = requestAnimationFrame(draw);
    }

    link.addEventListener('mouseenter', () => { if (!raf) draw(); });
    link.addEventListener('mouseleave', () => {
      if (raf !== null) { cancelAnimationFrame(raf); raf = null; }
      ctx.clearRect(0, 0, SIZE, SIZE);
    });
  })();

  // ── Devs icon (matrix drip) ───────────────────────────────────────
  (function() {
    const link   = document.querySelector<HTMLElement>('.nav-link--devs');
    const canvas = document.querySelector<HTMLCanvasElement>('.devs-canvas');
    const ctx    = canvas?.getContext('2d') ?? null;
    if (!link || !canvas || !ctx) return;

    const DPR  = Math.min(window.devicePixelRatio || 1, 2);
    const SIZE = 22;
    canvas.width  = SIZE * DPR;
    canvas.height = SIZE * DPR;
    ctx.scale(DPR, DPR);

    let raf: number | null = null;

    const FONT      = 6;
    const ROWS      = Math.ceil(SIZE / FONT);
    const TRAIL     = 3;
    const randBit   = () => Math.random() > 0.5 ? '1' : '0';
    const makeChars = () => Array.from({ length: ROWS }, randBit);

    const columns = [
      { x: 4,  drop: -1,         speed: 0.065 },
      { x: 11, drop: -ROWS * 0.5, speed: 0.05  },
      { x: 18, drop: -ROWS * 0.8, speed: 0.075 },
    ].map(c => ({ ...c, chars: makeChars() }));

    function draw() {
      const color = getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim() || '#e800d4';
      ctx.clearRect(0, 0, SIZE, SIZE);
      ctx.font = `bold ${FONT}px monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';

      columns.forEach(col => {
        const head = Math.floor(col.drop);
        for (let r = Math.max(0, head - TRAIL + 1); r <= Math.min(head, ROWS - 1); r++) {
          const dist = head - r;
          ctx.fillStyle = color;
          ctx.globalAlpha = dist === 0 ? 0.9 : (1 - dist / TRAIL) * 0.55;
          ctx.fillText(col.chars[r], col.x, r * FONT + 1);
        }
        col.drop += col.speed;
        if (col.drop > ROWS + TRAIL) {
          col.drop = -TRAIL;
          col.chars = makeChars();
        }
      });

      ctx.globalAlpha = 1;
      raf = requestAnimationFrame(draw);
    }

    link.addEventListener('mouseenter', () => { if (!raf) draw(); });
    link.addEventListener('mouseleave', () => {
      if (raf !== null) { cancelAnimationFrame(raf); raf = null; }
      ctx.clearRect(0, 0, SIZE, SIZE);
    });
  })();

  // ── Manifesto icon (scan cursor over text lines) ──────────────────
  (function() {
    const link   = document.querySelector<HTMLElement>('.nav-link--manifesto');
    const canvas = document.querySelector<HTMLCanvasElement>('.manifesto-canvas');
    const ctx    = canvas?.getContext('2d') ?? null;
    if (!link || !canvas || !ctx) return;

    const DPR  = Math.min(window.devicePixelRatio || 1, 2);
    const SIZE = 22;
    canvas.width  = SIZE * DPR;
    canvas.height = SIZE * DPR;
    ctx.scale(DPR, DPR);
    const CX = SIZE / 2;
    const CY = SIZE / 2;

    let raf: number | null = null;
    const lines = [
      { y: CY - 5, w: 13 },
      { y: CY,     w: 10 },
      { y: CY + 5, w: 7  },
    ];

    function draw() {
      const color = getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim() || '#e800d4';
      const scanT = (Date.now() / 900) % 1;
      const scanX = (CX - 8) + scanT * 16;
      ctx.clearRect(0, 0, SIZE, SIZE);

      lines.forEach(({ y, w }) => {
        const x0 = CX - w / 2;
        const x1 = CX + w / 2;

        // Base line
        ctx.beginPath();
        ctx.moveTo(x0, y);
        ctx.lineTo(x1, y);
        ctx.strokeStyle = color;
        ctx.lineWidth = 0.7;
        ctx.globalAlpha = 0.25;
        ctx.stroke();

        // Glow around scan position
        const dist = Math.abs(scanX - (x0 + x1) / 2);
        const glow = Math.max(0, 1 - dist / 9);
        if (glow > 0 && scanX >= x0 && scanX <= x1) {
          ctx.beginPath();
          ctx.moveTo(x0, y);
          ctx.lineTo(x1, y);
          ctx.lineWidth = 1.4;
          ctx.globalAlpha = glow * 0.9;
          ctx.stroke();
        }
      });

      // Scan cursor vertical line
      ctx.beginPath();
      ctx.moveTo(scanX, CY - 8);
      ctx.lineTo(scanX, CY + 8);
      ctx.strokeStyle = color;
      ctx.lineWidth = 0.6;
      ctx.globalAlpha = 0.35;
      ctx.stroke();

      ctx.globalAlpha = 1;
      raf = requestAnimationFrame(draw);
    }

    link.addEventListener('mouseenter', () => { if (!raf) draw(); });
    link.addEventListener('mouseleave', () => {
      if (raf !== null) { cancelAnimationFrame(raf); raf = null; }
      ctx.clearRect(0, 0, SIZE, SIZE);
    });
  })();

  // ── Temas icon (morphing circle → square → triangle) ─────────────
  (function() {
    const link   = document.querySelector<HTMLElement>('.nav-link--temas');
    const canvas = document.querySelector<HTMLCanvasElement>('.temas-canvas');
    const ctx    = canvas?.getContext('2d') ?? null;
    if (!link || !canvas || !ctx) return;

    const DPR  = Math.min(window.devicePixelRatio || 1, 2);
    const SIZE = 22;
    canvas.width  = SIZE * DPR;
    canvas.height = SIZE * DPR;
    ctx.scale(DPR, DPR);

    let raf: number | null = null;

    const CX = SIZE / 2, CY = SIZE / 2, R = SIZE / 2 - 2.5;
    const N = 12;
    type Pt = [number, number];

    function makeCircle(): Pt[] {
      return Array.from({ length: N }, (_, i) => {
        const a = (i / N) * Math.PI * 2 - Math.PI / 2;
        return [CX + R * Math.cos(a), CY + R * Math.sin(a)];
      });
    }

    function makeSquare(): Pt[] {
      const pts: Pt[] = [];
      const half = R / Math.sqrt(2);
      const pps  = N / 4;
      for (let s = 0; s < 4; s++) {
        for (let j = 0; j < pps; j++) {
          const t = j / pps;
          let x = 0, y = 0;
          if (s === 0) { x = CX - half + t * 2 * half; y = CY - half; }
          if (s === 1) { x = CX + half; y = CY - half + t * 2 * half; }
          if (s === 2) { x = CX + half - t * 2 * half; y = CY + half; }
          if (s === 3) { x = CX - half; y = CY + half - t * 2 * half; }
          pts.push([x, y]);
        }
      }
      return pts;
    }

    function makeTriangle(): Pt[] {
      const pts: Pt[] = [];
      const pps   = N / 3;
      const verts: Pt[] = [
        [CX, CY - R],
        [CX + R * Math.cos(Math.PI / 6), CY + R * Math.sin(Math.PI / 6)],
        [CX - R * Math.cos(Math.PI / 6), CY + R * Math.sin(Math.PI / 6)],
      ];
      for (let s = 0; s < 3; s++) {
        const [x0, y0] = verts[s];
        const [x1, y1] = verts[(s + 1) % 3];
        for (let j = 0; j < pps; j++) {
          const t = j / pps;
          pts.push([x0 + t * (x1 - x0), y0 + t * (y1 - y0)]);
        }
      }
      return pts;
    }

    const shapes = [makeCircle(), makeSquare(), makeTriangle()];

    function easeInOut(t: number) { return (1 - Math.cos(t * Math.PI)) / 2; }

    function lerpPts(a: Pt[], b: Pt[], t: number): Pt[] {
      const e = easeInOut(t);
      return a.map(([ax, ay], i) => [ax + (b[i][0] - ax) * e, ay + (b[i][1] - ay) * e]);
    }

    const PHASE = 1200;

    function draw() {
      const color = getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim() || '#e800d4';
      const raw   = (Date.now() % (PHASE * 3)) / PHASE;
      const phase = Math.floor(raw) % 3;
      const frac  = raw - Math.floor(raw);
      const pts   = lerpPts(shapes[phase], shapes[(phase + 1) % 3], frac);

      ctx.clearRect(0, 0, SIZE, SIZE);
      ctx.beginPath();
      ctx.moveTo(pts[0][0], pts[0][1]);
      for (let i = 1; i < N; i++) ctx.lineTo(pts[i][0], pts[i][1]);
      ctx.closePath();
      ctx.strokeStyle = color;
      ctx.lineWidth   = 1;
      ctx.globalAlpha = 0.82;
      ctx.stroke();
      ctx.globalAlpha = 1;

      raf = requestAnimationFrame(draw);
    }

    link.addEventListener('mouseenter', () => { if (!raf) draw(); });
    link.addEventListener('mouseleave', () => {
      if (raf !== null) { cancelAnimationFrame(raf); raf = null; }
      ctx.clearRect(0, 0, SIZE, SIZE);
    });
  })();

  // ── Theme buttons ─────────────────────────────────────────────────
  document.addEventListener('click', (e) => {
    const target = e.target as Element | null;
    const btn = target?.closest<HTMLButtonElement>('button[data-theme]');
    if (!btn) return;

    const key = btn.dataset.theme as ThemeKey;
    if (!key || !(key in themes)) return;

    e.preventDefault();
    closeAll();

    if (document.documentElement.dataset.theme === key) return;
    if (themes[key].dangerous) {
      pendingTheme = key;
      openModal();
    } else {
      forceApplyTheme(key);
    }
  }, { signal: navSignal });
</script>
