<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 32px;
    height: 52px;
    background: transparent;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-10px);
    transition: opacity 0.45s ease, transform 0.45s ease, visibility 0.45s ease;
  }

  .navbar.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0;
    font-family: monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-star);
    text-decoration: none;
    animation: nav-pulse 3s ease-in-out infinite;
    transition: color 0.22s ease, text-shadow 0.22s ease;
  }

  .nav-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  li:nth-child(1) .nav-link { animation-delay: 0s; }
  li:nth-child(2) .nav-link { animation-delay: 0.4s; }
  li:nth-child(3) .nav-link { animation-delay: 0.8s; }

  @keyframes nav-pulse {
    0%, 100% { text-shadow: 0 0 6px var(--color-star-40); opacity: 1; }
    50%       { text-shadow: 0 0 14px var(--color-star-90); opacity: 0.75; }
  }

  .nav-prefix {
    color: var(--color-star);
    transition: color 0.22s ease;
    margin-right: 1px;
  }

  .nav-link:hover {
    color: var(--color-accent);
    animation: none;
    text-shadow: 0 0 12px var(--color-accent-60);
  }

  .nav-link:hover .nav-prefix {
    color: var(--color-accent);
  }

  /* Dropdown */
  .has-dropdown {
    position: relative;
  }

  .dropdown {
    list-style: none;
    margin: 0;
    padding: 8px 0;
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 180px;
    background: var(--color-bg-88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-star-18);
    border-radius: 6px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
  }

  .dropdown.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    padding: 8px 18px;
    font-family: monospace;
    font-size: 0.59rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-star);
    text-decoration: none;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .dropdown-link:hover {
    color: var(--color-accent);
    background: var(--color-accent-06);
  }

  .dropdown-link:hover .nav-prefix {
    color: var(--color-accent);
  }

  .dropdown-btn {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  /* Limbo theme overrides (text handled globally by ThemeProvider) */
  :global(html[data-theme="limbo"]) .dropdown {
    background: rgba(255, 255, 255, 0.95) !important;
    border-color: rgba(0, 0, 0, 0.15) !important;
  }

  :global(html[data-theme="limbo"]) .dropdown-link:hover {
    background: rgba(0, 0, 0, 0.06) !important;
  }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-70);
    backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.22s ease, visibility 0.22s ease;
  }

  .modal-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .modal-box {
    background: var(--color-bg-95);
    border: 1px solid var(--color-star-25);
    border-radius: 8px;
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 360px;
    width: 90%;
    transform: translateY(8px);
    transition: transform 0.22s ease;
  }

  .modal-overlay.is-open .modal-box {
    transform: translateY(0);
  }

  .modal-warn {
    width: 36px;
    height: 36px;
    color: #ff2a2a;
    align-self: center;
    filter: drop-shadow(0 0 6px rgba(255, 42, 42, 0.7));
    animation: warn-pulse 1s ease-in-out infinite;
  }

  @keyframes warn-pulse {
    0%, 100% { opacity: 1;   filter: drop-shadow(0 0 6px rgba(255, 42, 42, 0.7)); }
    50%       { opacity: 0.3; filter: drop-shadow(0 0 2px rgba(255, 42, 42, 0.2)); }
  }

  .modal-question {
    margin: 0;
    font-family: monospace;
    font-size: 0.78rem;
    color: var(--color-star);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.6;
  }

  .modal-actions {
    display: flex;
    gap: 20px;
    justify-content: flex-end;
    margin-top: 8px;
  }

  .modal-btn {
    font-family: monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 10px 28px;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }

  .modal-btn--confirm {
    background: transparent;
    border: 1px outset var(--color-star);
    color: var(--color-star);
  }

  .modal-btn--confirm:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-08);
    box-shadow: 0 0 12px var(--color-accent-20);
  }

  .modal-btn--cancel {
    background: transparent;
    border: 1px solid var(--color-star-22);
    color: #5a8a94;
  }

  .modal-btn--cancel:hover {
    border-color: var(--color-star-40);
    color: #a0c4cc;
  }

  .modal-bye {
    display: none;
    font-family: monospace;
    font-size: 1rem;
    font-weight: bold;
    color: #ff2a2a;
    text-align: center;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    animation: warn-pulse 0.8s ease-in-out infinite;
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 0 16px;
    }

    .nav-links {
      gap: 18px;
    }

    .nav-link {
      font-size: 0.7rem;
    }

    .has-dropdown {
      position: static;
    }

    .dropdown {
      top: 44px;
      left: 50%;
      transform: translateX(-50%) translateY(-6px);
      width: min(92vw, 260px);
      min-width: 0;
      max-width: calc(100vw - 24px);
    }

    .dropdown.is-open {
      transform: translateX(-50%) translateY(0);
    }

    .dropdown-link {
      padding: 10px 16px;
      font-size: 0.62rem;
      white-space: normal;
      line-height: 1.45;
    }
  }
</style>

<script>
  import { applyTheme, themes, type ThemeKey } from '../lib/themes';

  // ── Navbar visibility ────────────────────────────────────────────
  // On the home page (/), the BlackHole animation fires 'animationComplete'
  // to reveal the navbar. On every other page we show it immediately.
  const INTRO_KEY = 'intro_last_shown';
  const TODAY     = new Date().toISOString().slice(0, 10);
  const navbar    = document.querySelector('.navbar') as HTMLElement | null;

  function showNavbar() {
    navbar?.classList.add('is-visible');
  }

  const isHome = window.location.pathname === '/' || window.location.pathname === '';
  if (!isHome || localStorage.getItem(INTRO_KEY) === TODAY) {
    showNavbar();
  } else {
    window.addEventListener('animationComplete', showNavbar, { once: true });
  }

  // ── Dropdowns ────────────────────────────────────────────────────
  const dropdowns = [
    { btn: document.getElementById('cat-btn'),   menu: document.getElementById('cat-menu') },
    { btn: document.getElementById('temas-btn'), menu: document.getElementById('temas-menu') },
  ];

  function closeAll(except?: Element) {
    dropdowns.forEach(({ btn, menu }) => {
      if (menu === except) return;
      menu?.classList.remove('is-open');
      btn?.setAttribute('aria-expanded', 'false');
    });
  }

  dropdowns.forEach(({ btn, menu }) => {
    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      closeAll(menu!);
      const open = menu?.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(open));
    });
  });

  document.addEventListener('click', () => closeAll());
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });

  // ── Theme modal ───────────────────────────────────────────────────
  const modal              = document.getElementById('theme-modal')!;
  const modalConfirm       = document.getElementById('modal-confirm')!;
  const modalCancel        = document.getElementById('modal-cancel')!;
  const modalDefaultContent = document.getElementById('modal-default-content')!;
  const modalBye           = document.getElementById('modal-bye')!;
  let pendingTheme: ThemeKey | null = null;

  function openModal()  {
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    pendingTheme = null;
  }

  modalConfirm.addEventListener('click', () => {
    if (pendingTheme === 'limbo') {
      modalDefaultContent.style.display = 'none';
      modalBye.style.display = 'block';
      modalBye.setAttribute('aria-hidden', 'false');
      setTimeout(() => {
        applyTheme('limbo');
        closeModal();
        modalDefaultContent.style.display = '';
        modalBye.style.display = 'none';
        modalBye.setAttribute('aria-hidden', 'true');
      }, 1500);
    } else {
      if (pendingTheme) applyTheme(pendingTheme);
      closeModal();
    }
  });

  modalCancel.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ── Theme buttons ─────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-theme]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.theme as ThemeKey;
      if (!key || !(key in themes)) return;
      closeAll();
      if (themes[key].dangerous) {
        pendingTheme = key;
        openModal();
      } else {
        applyTheme(key);
      }
    });
  });
</script>
