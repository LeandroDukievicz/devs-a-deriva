---
import StarBackground from './StarBackground.astro';

interface Props {
  code?: string;
}

const { code = '404' } = Astro.props;
const digits = code.padEnd(3, '0').slice(0, 3).split('');
---

<StarBackground />

<section class="page-overlay">

  <div class="visual-block" aria-hidden="true">
    <!-- Dígito do Meio (Back) -->
    <div class="float-element float-1">
      <svg
        class="error-code-shadow error-code-shadow-back"
        viewBox="0 0 1200 500"
        role="presentation"
      >
        <text x="600" y="320">{digits[1]}</text>
      </svg>

      <svg
        class="error-code error-code-back"
        viewBox="0 0 1200 500"
        role="presentation"
      >
        <defs>
          <linearGradient id="error-code-gradient-back" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#00d4e8" />
            <stop offset="100%" stop-color="#e800d4" />
          </linearGradient>
        </defs>
        <text x="600" y="320">{digits[1]}</text>
      </svg>
    </div>

    <!-- Dígitos Laterais (Front) -->
    <div class="float-element float-2">
      <svg
        class="error-code-shadow error-code-shadow-front"
        viewBox="0 0 1200 500"
        role="presentation"
      >
        <text x="395" y="320">{digits[0]}</text>
      </svg>
      <svg
        class="error-code error-code-front"
        viewBox="0 0 1200 500"
        role="presentation"
      >
        <defs>
          <linearGradient id="error-code-gradient-front" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#00d4e8" />
            <stop offset="100%" stop-color="#e800d4" />
          </linearGradient>
        </defs>
        <text x="395" y="320">{digits[0]}</text>
      </svg>
    </div>

    <div class="float-element float-3">
      <svg
        class="error-code-shadow error-code-shadow-front"
        viewBox="0 0 1200 500"
        role="presentation"
      >
        <text x="805" y="320">{digits[2]}</text>
      </svg>
      <svg
        class="error-code error-code-front"
        viewBox="0 0 1200 500"
        role="presentation"
      >
        <text x="805" y="320">{digits[2]}</text>
      </svg>
    </div>

    <div class="float-element float-helmet">
      <img
        src="/helmet-error-404.webp"
        alt=""
        width="499"
        height="500"
        class="helmet-image"
      />
    </div>
  </div>

  <div class="error-copy">
    <p class="error-title">Página não encontrada</p>
    <p class="error-subtitle">Parece que você se perdeu no espaço</p>
    <a href="/" class="error-cta">Voltar à órbita inicial</a>
  </div>
</section>

<style>
  .page-overlay {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 52px 24px 24px;
    transform: translateY(-150px);
  }

  .visual-block {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    min-height: calc(100vh - 76px);
  }

  .float-element {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  .float-1 {
    animation: float-random-1 7s ease-in-out infinite;
  }

  .float-2 {
    animation: float-random-2 8s ease-in-out infinite;
  }

  .float-3 {
    animation: float-random-3 9s ease-in-out infinite;
  }

  .float-helmet {
    animation: float-random-helmet 6s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes float-random-1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(5px, -15px) rotate(1deg); }
    66% { transform: translate(-5px, 10px) rotate(-1deg); }
  }

  @keyframes float-random-2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(-8px, 12px) rotate(-1.5deg); }
    66% { transform: translate(8px, -10px) rotate(1deg); }
  }

  @keyframes float-random-3 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(10px, 8px) rotate(1.2deg); }
    66% { transform: translate(-10px, -12px) rotate(-0.8deg); }
  }

  @keyframes float-random-helmet {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(-12px, -8px) rotate(-2deg); }
    66% { transform: translate(12px, 15px) rotate(2deg); }
  }

  .visual-block::before {
    content: '';
    position: absolute;
    width: min(72vw, 320px);
    height: min(72vw, 320px);
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      rgba(0, 212, 232, 0.18) 0%,
      rgba(0, 212, 232, 0.08) 38%,
      rgba(232, 0, 212, 0.08) 62%,
      rgba(232, 0, 212, 0.16) 100%
    );
    filter: blur(28px);
    opacity: 0.9;
    pointer-events: none;
  }

  .error-code {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(92vw, 980px);
    height: auto;
    overflow: visible;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .error-code text {
    fill: transparent;
    stroke-width: 8;
    font-family: monospace;
    font-size: 380px;
    font-weight: 700;
    text-anchor: middle;
    dominant-baseline: middle;
    letter-spacing: 0;
  }

  .error-code-shadow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(92vw, 980px);
    height: auto;
    overflow: visible;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .error-code-shadow text {
    fill: transparent;
    stroke-width: 18;
    stroke: rgba(0, 212, 232, 0.16);
    font-family: monospace;
    font-size: 380px;
    font-weight: 700;
    text-anchor: middle;
    dominant-baseline: middle;
    letter-spacing: 0;
    filter: blur(10px);
  }

  .error-code-shadow-back {
    z-index: 0;
  }

  .error-code-shadow-front {
    z-index: 0;
  }

  .error-code-back {
    z-index: 0;
  }

  .error-code-shadow-front text {
    stroke: rgba(232, 0, 212, 0.14);
  }

  .error-code-back text {
    stroke: url(#error-code-gradient-back);
  }

  .error-code-front {
    z-index: 0;
  }

  .error-code-front text {
    stroke: url(#error-code-gradient-front);
  }

  .helmet-image {
    position: relative;
    z-index: 1;
    display: block;
    width: min(100%, 348px);
    height: auto;
  }

  .error-copy {
    margin-top: -140px;
    text-align: center;
    pointer-events: auto;
    position: relative;
    z-index: 3;
  }

  .error-title,
  .error-subtitle {
    margin: 0;
    font-family: monospace;
    letter-spacing: 0.08em;
  }

  .error-title {
    color: #00d4e8;
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    text-transform: uppercase;
  }

  .error-subtitle {
    margin-top: 12px;
    color: #ffffff;
    font-size: clamp(0.88rem, 1.3vw, 1rem);
  }

  .error-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 24px;
    min-height: 44px;
    min-width: 208px;
    padding: 0 29px;
    border: 1px outset #00d4e8;
    border-radius: 999px;
    color: #00d4e8;
    background: transparent;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-family: monospace;
    font-size: 0.72rem;
    transition:
      color 0.32s ease,
      border-color 0.32s ease,
      background 0.32s ease,
      box-shadow 0.32s ease,
      transform 0.32s ease;
  }

  .error-cta:hover,
  .error-cta:focus-visible {
    transform: translateY(-2px);
    box-shadow:
      0 0 14px rgba(0, 212, 232, 0.16),
      0 0 26px rgba(0, 212, 232, 0.1);
    animation: cta-pulse 1.8s ease-in-out infinite;
  }

  @keyframes cta-pulse {
    0%, 100% {
      box-shadow:
        0 0 14px rgba(0, 212, 232, 0.16),
        0 0 26px rgba(0, 212, 232, 0.1);
    }
    50% {
      box-shadow:
        0 0 18px rgba(0, 212, 232, 0.24),
        0 0 34px rgba(0, 212, 232, 0.16);
    }
  }

  @media (max-width: 860px) {
    .page-overlay {
      padding-top: 48px;
    }

    .visual-block {
      min-height: calc(100vh - 64px);
    }

    .float-1,
    .float-2,
    .float-3 {
      top: -90px;
    }

    .float-helmet {
      top: 90px;
    }

    .error-code {
      width: min(96vw, 760px);
    }

    .error-code-shadow {
      width: min(96vw, 760px);
    }

    .error-code text {
      font-size: 300px;
      stroke-width: 7;
    }

    .error-code-shadow text {
      font-size: 300px;
      stroke-width: 16;
    }

    .error-copy {
      margin-top: -90px;
    }
  }

  @media (max-width: 520px) {
    .page-overlay {
      padding-top: 40px;
      padding-left: 16px;
      padding-right: 16px;
    }

    .float-1,
    .float-2,
    .float-3 {
      top: -110px;
    }

    .float-helmet {
      top: 110px;
    }

    .error-code {
      width: min(100vw, 520px);
    }

    .error-code-shadow {
      width: min(100vw, 520px);
    }

    .error-code text {
      font-size: 208px;
      stroke-width: 6;
    }

    .error-code-shadow text {
      font-size: 208px;
      stroke-width: 12;
    }

    .helmet-image {
      width: min(100%, 220px);
    }

    .error-copy {
      margin-top: -40px;
    }
  }
</style>
