---
/**
 * ThemeProvider — keeps the single site theme stable before first paint.
 *
 * Orbita Baixa is the only supported theme. The inline script removes old
 * persisted theme values so previous sessions cannot force legacy themes.
 */
---

<script is:inline>
  try {
    var THEME = 'orbita-baixa';
    var STORAGE_KEY = 'dda-theme';
    var root = document.documentElement;
    var vars = {
      '--color-bg': '#020b18',
      '--color-star': '#00d4e8',
      '--color-accent': '#e800d4',
      '--color-text': '#e8f4f8'
    };

    document.documentElement.dataset.theme = THEME;
    Object.keys(vars).forEach(function(key) {
      root.style.setProperty(key, vars[key]);
    });
    root.style.backgroundColor = '#020b18';
    window.__bgColor = '#020b18';
    try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
    try { sessionStorage.removeItem(STORAGE_KEY); } catch (_) {}
  } catch (_) {}
</script>
