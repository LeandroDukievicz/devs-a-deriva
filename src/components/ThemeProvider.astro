---
/**
 * ThemeProvider — drop inside <head> on every page.
 *
 * Restores the saved theme from localStorage before the first paint
 * to prevent flash of wrong background.
 *
 * CSS variables and theme overrides live in src/styles/tokens.css,
 * imported once by src/layouts/Base.astro.
 */
---

<script is:inline>
  try {
    var palettes = {
      'orbita-baixa': {
        bg: [2, 11, 24],
        star: [0, 212, 232],
        accent: [232, 0, 212],
        text: [232, 244, 248]
      },
      'espaco-profundo': {
        bg: [0, 0, 0],
        star: [0, 122, 143],
        accent: [148, 0, 184],
        text: [232, 244, 248]
      },
      limbo: {
        bg: [255, 255, 255],
        star: [0, 0, 0],
        accent: [0, 0, 0],
        text: [0, 0, 0]
      }
    };

    function rgb(c, alpha) {
      return alpha === undefined
        ? 'rgb(' + c[0] + ' ' + c[1] + ' ' + c[2] + ')'
        : 'rgb(' + c[0] + ' ' + c[1] + ' ' + c[2] + ' / ' + alpha + ')';
    }

    function mix(c, other, amount) {
      var inverse = 1 - amount;
      return rgb([
        Math.round(c[0] * amount + other[0] * inverse),
        Math.round(c[1] * amount + other[1] * inverse),
        Math.round(c[2] * amount + other[2] * inverse)
      ]);
    }

    function setThemeVars(key) {
      var palette = palettes[key];
      if (!palette) return;

      var root = document.documentElement;
      root.dataset.theme = key;
      root.style.setProperty('--color-bg', rgb(palette.bg));
      root.style.setProperty('--color-star', rgb(palette.star));
      root.style.setProperty('--color-accent', rgb(palette.accent));
      root.style.setProperty('--color-text', rgb(palette.text));
      root.style.setProperty('--color-star-light', mix(palette.star, [255, 255, 255], 0.7));
      root.style.setProperty('--color-star-dark', mix(palette.star, [0, 0, 0], 0.7));

      [5, 8, 10, 16, 18, 22, 25, 40, 45, 70, 90].forEach(function(value) {
        root.style.setProperty('--color-star-' + String(value).padStart(2, '0'), rgb(palette.star, value / 100));
      });

      [6, 8, 14, 16, 18, 20, 40, 60].forEach(function(value) {
        root.style.setProperty('--color-accent-' + String(value).padStart(2, '0'), rgb(palette.accent, value / 100));
      });

      [70, 88, 90, 95].forEach(function(value) {
        root.style.setProperty('--color-bg-' + value, rgb(palette.bg, value / 100));
      });
    }

    window.__applyDdaTheme = function(key) {
      if (!palettes[key]) return false;
      setThemeVars(key);
      sessionStorage.setItem('dda-theme', key);
      window.__bgColor = rgb(palettes[key].bg);
      window.dispatchEvent(new CustomEvent('dda-theme-change', { detail: { theme: key } }));
      return true;
    };

    var t = sessionStorage.getItem('dda-theme');
    if (t && palettes[t]) {
      window.__applyDdaTheme(t);
    }
  } catch (_) {}
</script>
