---
import { getFeaturedByCategory, getPostsByCategory } from '../lib/posts';

interface Props {
  category: string;
  categorySlug: string;
  description: string;
  cornerIllustration?: string;
  animateIllustration?: boolean;
}

const {
  category,
  categorySlug,
  description,
  cornerIllustration,
  animateIllustration = false,
} = Astro.props;

const featuredPosts = getFeaturedByCategory(categorySlug);
const allPosts = getPostsByCategory(categorySlug);
---

<div class="categoria-page">
  {cornerIllustration && (
    <div
      class={`categoria-corner-illustration${animateIllustration ? ' is-animated' : ''}`}
      aria-hidden="true"
    >
      <span
        class="corner-astronaut"
        style={`--corner-illustration: url("${cornerIllustration}")`}
      ></span>
    </div>
  )}

  <!-- ── Header ─────────────────────────────────────────────────── -->
  <header class="categoria-header">
    <div class="categoria-info">
      <h1 class="categoria-title">
        <span class="cat-prefix">&gt;_</span>{category}
      </h1>
      <p class="categoria-desc">{description}</p>
      <span class="categoria-count">{allPosts.length} {allPosts.length === 1 ? 'post' : 'posts'}</span>
    </div>
  </header>

  <div class="categoria-divider"></div>

  <!-- ── Destaques ──────────────────────────────────────────────── -->
  <section class="destaques-section">
    <div class="section-label">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
      </svg>
      DESTAQUES DA CATEGORIA
    </div>

    <div class="carousel-wrapper">
      <button class="carousel-btn prev" id="carousel-prev" aria-label="Anterior">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <div class="carousel-viewport">
        <div class="carousel-track" id="carousel-track">
          {featuredPosts.map((post, i) => (
            <a href={`/posts/${post.slug}?from=category`} class="feat-card" data-index={i}>
              <div class="feat-card-body">
                <span class="card-tag">{category.toUpperCase()}</span>
                <h3 class="feat-card-title">{post.title}</h3>
                <div class="card-meta">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                  {post.readTime}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <button class="carousel-btn next" id="carousel-next" aria-label="Próximo">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>

    <div class="carousel-dots" id="carousel-dots"></div>
  </section>

  <!-- ── Todos os Posts ─────────────────────────────────────────── -->
  <section class="posts-section">
    <div class="section-label">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
      </svg>
      TODOS OS POSTS
    </div>

    <div class="posts-grid">
      {allPosts.map(post => (
        <a href={`/posts/${post.slug}?from=category`} class="post-card">
          <div class="post-card-body">
            <span class="card-tag">{category.toUpperCase()}</span>
            <h3 class="post-card-title">{post.title}</h3>
            <p class="post-card-excerpt">{post.excerpt}</p>
            <div class="post-card-meta">
              <div class="card-meta">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
                {post.readTime}
              </div>
              <span class="post-hashtag">{post.hashtag}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="load-more-wrap">
      <button class="load-more-btn">
        CARREGAR MAIS POSTS
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
      </button>
    </div>
  </section>
</div>

<style is:global>
  #nav-logo-link {
    display: none !important;
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.feat-card[href*="/posts/"], .post-card[href*="/posts/"]').forEach((link) => {
    link.addEventListener('click', () => {
      sessionStorage.setItem('post-nav-origin', 'category');
    });
  });
</script>

<style>
  /* ── Page wrapper ──────────────────────────────────────────── */
  .categoria-page {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    padding-top: 72px;
  }

  .categoria-corner-illustration {
    position: absolute;
    top: 82px;
    right: 28px;
    z-index: -1;
    width: min(18.6vw, 211px);
    aspect-ratio: 3 / 2;
    pointer-events: none;
    color: var(--color-star);
    opacity: 0.34;
  }

  .corner-astronaut {
    position: absolute;
    inset: 0;
    display: block;
    background: var(--color-star);
    filter: drop-shadow(0 0 18px var(--color-star-45));
    mask-image: var(--corner-illustration);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
    -webkit-mask-image: var(--corner-illustration);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    transform-origin: 50% 50%;
    opacity: 0.58;
  }

  .categoria-corner-illustration.is-animated .corner-astronaut {
    animation: astronaut-float 7.5s ease-in-out infinite;
  }

  @keyframes astronaut-float {
    0%, 100% {
      transform: translate3d(0, 0, 0) rotate(-0.6deg);
    }
    50% {
      transform: translate3d(-3px, -14px, 0) rotate(0.8deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .corner-astronaut {
      animation: none;
    }
  }

  /* ── Header ────────────────────────────────────────────────── */
  .categoria-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 32px;
    padding: 24px 48px 28px;
  }

  .categoria-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    opacity: 0;
    animation: cat-fade-info 0.65s ease 0.25s forwards;
  }

  @keyframes cat-fade-info {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .categoria-title {
    margin: 0;
    font-family: monospace;
    font-size: clamp(1.3rem, 3.5vw, 2.2rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-star);
    text-shadow: 0 0 20px var(--color-star-40);
    line-height: 1.1;
  }

  .cat-prefix {
    color: var(--color-accent);
    margin-right: 6px;
  }

  .categoria-desc {
    margin: 0;
    font-family: monospace;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--color-star);
    opacity: 0.5;
    line-height: 1.6;
    max-width: 480px;
  }

  .categoria-count {
    font-family: monospace;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    opacity: 0.7;
  }

  .categoria-divider {
    margin: 0 48px;
    height: 1px;
    background: linear-gradient(
      to right,
      var(--color-star),
      var(--color-accent),
      transparent
    );
    opacity: 0.35;
  }

  /* ── Section label ─────────────────────────────────────────── */
  .section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: monospace;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-star);
    margin-bottom: 20px;
  }

  .section-label svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* ── Shared card styles ────────────────────────────────────── */
  .card-tag {
    display: inline-block;
    font-family: monospace;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 8px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: monospace;
    font-size: 0.62rem;
    color: var(--color-star);
    opacity: 0.55;
  }

  /* ── Destaques / Carousel ──────────────────────────────────── */
  .destaques-section {
    padding: 36px 48px 0;
  }

  .carousel-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .carousel-viewport {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .carousel-viewport::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--color-star) 35%,
      var(--color-star) 65%,
      transparent 100%
    );
    box-shadow: 0 0 10px var(--color-star-70), 0 0 24px var(--color-star-40);
    pointer-events: none;
    opacity: 0;
    z-index: 2;
  }

  .carousel-viewport.scanning-next::after {
    animation: scan-next 0.45s ease-in-out forwards;
  }

  .carousel-viewport.scanning-prev::after {
    animation: scan-prev 0.45s ease-in-out forwards;
  }

  @keyframes scan-next {
    0%   { left: 0%;    opacity: 1; }
    80%  { opacity: 0.5; }
    100% { left: 100%;  opacity: 0; }
  }

  @keyframes scan-prev {
    0%   { left: 100%;  opacity: 1; }
    80%  { opacity: 0.5; }
    100% { left: 0%;    opacity: 0; }
  }

  .carousel-track {
    display: flex;
    gap: 16px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .feat-card {
    flex: 0 0 calc(25% - 12px);
    min-width: 0;
    background: transparent;
    border: 1px solid var(--color-star);
    border-radius: 10px;
    cursor: pointer;
    text-decoration: none;
    display: block;
    transition: border-color 0.22s ease;
  }

  .feat-card:hover {
    border-color: var(--color-accent);
  }

  .feat-card-body {
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 140px;
    justify-content: flex-end;
  }

  .feat-card-title {
    margin: 0;
    font-family: monospace;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }

  .carousel-btn {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--color-star);
    cursor: pointer;
    transition: color 0.2s ease, filter 0.2s ease;
  }

  .carousel-btn:hover {
    color: var(--color-accent);
    filter: drop-shadow(0 0 6px var(--color-accent));
  }

  .carousel-btn:disabled {
    opacity: 0.25;
    cursor: default;
    pointer-events: none;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
    margin-bottom: 4px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-star);
    opacity: 0.35;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .dot.active {
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent);
    opacity: 1;
    transform: scale(1.25);
  }

  /* ── Posts Grid ────────────────────────────────────────────── */
  .posts-section {
    padding: 40px 48px 48px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .post-card {
    background: transparent;
    border: 1px solid var(--color-star);
    border-radius: 10px;
    cursor: pointer;
    text-decoration: none;
    display: block;
    transition: border-color 0.22s ease;
  }

  .post-card:hover {
    border-color: var(--color-accent);
  }

  .post-card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .post-card-title {
    margin: 0;
    font-family: monospace;
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
  }

  .post-card-excerpt {
    margin: 0;
    font-family: monospace;
    font-size: 0.68rem;
    line-height: 1.6;
    color: var(--color-text);
    opacity: 0.55;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 6px;
  }

  .post-hashtag {
    font-family: monospace;
    font-size: 0.6rem;
    color: var(--color-accent);
    opacity: 0.8;
  }

  /* ── Load More ─────────────────────────────────────────────── */
  .load-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 36px;
  }

  .load-more-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: transparent;
    border: 1px dashed var(--color-accent);
    border-radius: 6px;
    padding: 14px 32px;
    cursor: pointer;
    transition: border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
  }

  .load-more-btn:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 18px var(--color-accent-20);
    background: transparent;
  }

  /* ── Mobile ────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .categoria-corner-illustration {
      width: min(23.5vw, 157px);
      right: 12px;
      opacity: 0.24;
    }

    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .feat-card {
      flex: 0 0 calc(50% - 8px);
    }
  }

  @media (max-width: 600px) {
    .categoria-corner-illustration {
      display: none;
    }
    .categoria-header {
      gap: 20px;
      padding: 20px 20px 24px;
    }
    .categoria-img {
      width: 100px;
      height: 100px;
      border-radius: 10px;
    }
    .categoria-divider { margin: 0 20px; }
    .destaques-section { padding: 28px 20px 0; }
    .posts-section { padding: 32px 20px 40px; }
    .posts-grid { grid-template-columns: 1fr; }
    .feat-card {
      flex: 0 0 calc(100% - 0px);
    }
    .carousel-btn { display: none; }
  }
</style>

<script>
  const track = document.getElementById('carousel-track') as HTMLElement;
  const dotsContainer = document.getElementById('carousel-dots') as HTMLElement;
  const prevBtn = document.getElementById('carousel-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('carousel-next') as HTMLButtonElement;

  if (track && dotsContainer && prevBtn && nextBtn) {
    const viewport = track.parentElement as HTMLElement;
    const cards = Array.from(track.querySelectorAll<HTMLElement>('.feat-card'));
    let current = 0;
    let scanTimer: ReturnType<typeof setTimeout> | null = null;
    let autoTimer: ReturnType<typeof setTimeout> | null = null;
    const AUTO_INTERVAL = 4000;

    function getVisible(): number {
      if (window.innerWidth <= 600) return 1;
      if (window.innerWidth <= 900) return 2;
      return 4;
    }

    function maxIndex(): number {
      return Math.max(0, cards.length - getVisible());
    }

    function buildDots() {
      const total = maxIndex() + 1;
      dotsContainer.innerHTML = '';
      for (let i = 0; i < total; i++) {
        const btn = document.createElement('button');
        btn.className = 'dot' + (i === current ? ' active' : '');
        btn.setAttribute('aria-label', `Ir para destaque ${i + 1}`);
        btn.addEventListener('click', () => {
          const dir = i > current ? 'next' : 'prev';
          current = i;
          update(dir);
          scheduleAuto();
        });
        dotsContainer.appendChild(btn);
      }
    }

    function syncDots() {
      Array.from(dotsContainer.querySelectorAll<HTMLButtonElement>('.dot'))
        .forEach((dot, i) => dot.classList.toggle('active', i === current));
    }

    function triggerScan(direction: 'next' | 'prev') {
      if (scanTimer) clearTimeout(scanTimer);
      viewport.classList.remove('scanning-next', 'scanning-prev');
      void viewport.offsetWidth;
      viewport.classList.add(`scanning-${direction}`);
      scanTimer = setTimeout(() => {
        viewport.classList.remove('scanning-next', 'scanning-prev');
      }, 450);
    }

    function update(direction?: 'next' | 'prev') {
      const cardEl = cards[0];
      if (!cardEl) return;
      const gap = 16;
      const cardWidth = cardEl.getBoundingClientRect().width;
      track.style.transform = `translateX(-${current * (cardWidth + gap)}px)`;
      syncDots();
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current >= maxIndex();
      if (direction) triggerScan(direction);
    }

    function scheduleAuto() {
      if (autoTimer) clearTimeout(autoTimer);
      autoTimer = setTimeout(() => {
        current = current >= maxIndex() ? 0 : current + 1;
        update('next');
        scheduleAuto();
      }, AUTO_INTERVAL);
    }

    function stopAuto() {
      if (autoTimer) { clearTimeout(autoTimer); autoTimer = null; }
    }

    prevBtn.addEventListener('click', () => {
      if (current > 0) { current--; update('prev'); scheduleAuto(); }
    });

    nextBtn.addEventListener('click', () => {
      if (current < maxIndex()) { current++; update('next'); scheduleAuto(); }
    });

    viewport.addEventListener('mouseenter', stopAuto);
    viewport.addEventListener('mouseleave', scheduleAuto);

    window.addEventListener('resize', () => {
      const prev = maxIndex();
      current = Math.min(current, maxIndex());
      if (maxIndex() !== prev) buildDots();
      update();
    }, { passive: true });

    buildDots();
    update();
    scheduleAuto();
  }
</script>
