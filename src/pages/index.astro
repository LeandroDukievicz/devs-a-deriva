  <style>
    .page-overlay {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      z-index: 10;
      display: flex;
      align-items: flex-start;
      padding-top: 100px;
      justify-content: center;
      pointer-events: none;
    }

    .sections-container {
      width: 60%;
      height: 115vh;
      display: flex;
      flex-direction: column;
      gap: 50px;
      transform: translateX(-100px);
      opacity: 0;
      transition: opacity 1.2s ease-in-out;
      pointer-events: auto;
    }

    .content-section {
      flex: 1;
      display: flex;
      flex-direction: row;
      box-sizing: border-box;
      border: 1px outset #00d4e8;
      border-radius: 8px;
      overflow: hidden;
      transition: border-color 0.3s ease;
    }

    .section-image {
      flex: 0 0 35%;
      margin: 15px;
      padding: 5px;
      border-radius: 6px;
      background: rgba(0, 212, 232, 0.05);
      border-right: 1px solid rgba(0, 212, 232, 0.2);
      box-sizing: border-box;
    }

    .section-body {
      flex: 1;
      display: flex;
      flex-direction: row;
    }

    .section-info {
      flex: 1;
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
    }

    .section-text {
      flex: 0 0 50%;
      padding: 20px 16px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    .cta-read {
      margin-top: auto;
      align-self: flex-end;
      font-size: 0.72rem;
      font-family: monospace;
      color: #00d4e8;
      text-decoration: none;
      padding: 5px 0;
      transition: color 0.2s;
    }

    .cta-read:hover {
      color: #e800d4;
    }

    .dot {
      display: inline-block;
      animation: wave-dot 1.2s ease-in-out infinite;
    }

    @keyframes wave-dot {
      0%, 100% { transform: translateY(0);    opacity: 1;   }
      50%       { transform: translateY(-4px); opacity: 0.4; }
    }

    .content-section:hover {
      border-color: #e800d4;
    }

    .content-section h2 {
      margin: 0 0 8px;
      font-size: 1rem;
      font-weight: 600;
      color: #00d4e8;
      font-family: monospace;
    }

    .content-section p {
      margin: 0 0 10px;
      font-size: 0.82rem;
      color: #a0c4cc;
      font-family: monospace;
      line-height: 1.6;
    }

    .post-meta {
      display: block;
      font-size: 0.75rem;
      color: #5a8a94;
      font-family: monospace;
      margin-bottom: 12px;
    }

    .post-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-top: auto;
      padding-bottom: 4px;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      color: #00d4e8;
      background: transparent;
      border: 1px outset #00d4e8;
      border-radius: 50%;
      cursor: pointer;
      text-decoration: none;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }

    .cta-btn:hover {
      color: #e800d4;
      border-color: #e800d4;
      background: rgba(232, 0, 212, 0.08);
    }
  </style>

  <script>
    window.addEventListener('animationComplete', () => {
      const container = document.getElementById('sections-container');
      if (container) container.style.opacity = '1';
    });

    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const original = btn.textContent?.trim();
          btn.textContent = 'Copiado!';
          setTimeout(() => { if (original) btn.textContent = original; }, 2000);
        });
      });
    });
  </script>
</html>
