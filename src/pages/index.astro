  <script>
    window.addEventListener('animationComplete', () => {
      const container = document.getElementById('sections-container');
      if (container) {
        container.style.opacity = '1';
        container.style.transform = 'translate3d(0, 0, 0)';
      }
    });

    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const original = btn.textContent?.trim();
          btn.textContent = 'Copiado!';
          setTimeout(() => { if (original) btn.textContent = original; }, 2000);
        });
      });
    });

    const LIMBO_SLICE_COUNT = 36;

    function easeInCubic(x: number) {
      return x * x * x;
    }

    function easeInQuint(x: number) {
      return x * x * x * x * x;
    }

    function createSliceClone(section: HTMLElement, rect: DOMRect, sliceTop: number, sliceHeight: number) {
      const slice = document.createElement('div');
      slice.className = 'limbo-slice';
      slice.style.left = `${rect.left}px`;
      slice.style.top = `${sliceTop}px`;
      slice.style.width = `${rect.width}px`;
      slice.style.height = `${sliceHeight}px`;

      const content = document.createElement('div');
      content.className = 'limbo-slice-content';
      content.style.width = `${rect.width}px`;
      content.style.height = `${rect.height}px`;
      content.style.top = `${-(sliceTop - rect.top)}px`;

      const clone = section.cloneNode(true) as HTMLElement;
      clone.classList.remove('is-vanishing');
      clone.style.margin = '0';
      clone.style.width = `${rect.width}px`;
      clone.style.height = `${rect.height}px`;
      clone.style.transform = 'none';
      clone.style.boxShadow = getComputedStyle(section).boxShadow;
      clone.querySelectorAll('a, button').forEach((el) => {
        (el as HTMLElement).setAttribute('tabindex', '-1');
      });

      content.appendChild(clone);
      slice.appendChild(content);
      return { slice, content };
    }

    function vanishSection(section: HTMLElement) {
      if (section.classList.contains('is-vanishing')) return;
      const rect = section.getBoundingClientRect();
      const overlay = document.createElement('div');
      overlay.className = 'limbo-overlay';

      const targetX = window.innerWidth;
      const targetY = 0;
      const sectionCenterX = rect.left + rect.width / 2;
      const sectionCenterY = rect.top + rect.height / 2;
      const dx = targetX - sectionCenterX;
      const dy = targetY - sectionCenterY;
      const len = Math.max(1, Math.sqrt(dx * dx + dy * dy));
      const ny = dy / len;
      const sliceHeight = rect.height / LIMBO_SLICE_COUNT;
      const slices: Array<{
        slice: HTMLDivElement;
        content: HTMLDivElement;
        centerY: number;
      }> = [];

      for (let i = 0; i < LIMBO_SLICE_COUNT; i++) {
        const sliceTop = rect.top + sliceHeight * i;
        const sliceData = createSliceClone(section, rect, sliceTop, sliceHeight + 1);
        overlay.appendChild(sliceData.slice);
        slices.push({
          ...sliceData,
          centerY: sliceTop + sliceHeight * 0.5,
        });
      }

      document.body.appendChild(overlay);
      section.style.setProperty('--limbo-x', `${dx}px`);
      section.style.setProperty('--limbo-y', `${dy}px`);
      section.classList.add('is-vanishing');

      const startTime = performance.now();
      const duration = 960;

      function frame(now: number) {
        const p = Math.min(1, (now - startTime) / duration);
        const globalFade = Math.max(0, 1 - easeInQuint(Math.max(0, (p - 0.78) / 0.22)));

        slices.forEach(({ slice, content, centerY }) => {
          const proj = ((centerY - sectionCenterY) * ny) / Math.max(rect.height / 2, 1);
          const pullFactor = (proj + 1) / 2;
          const sliceP = Math.min(1, p * (0.2 + pullFactor * 1.6));
          const moveX = dx * easeInQuint(sliceP) * 0.94;
          const moveY = dy * easeInQuint(sliceP) * 0.94;
          const stretchP = Math.max(0, (sliceP - 0.25) / 0.75);
          const stretch = 1 + easeInCubic(stretchP) * 9.5;
          const squish = Math.max(0.015, 1 - easeInCubic(stretchP) * 0.985);
          const opacity = Math.max(0, 1 - easeInQuint(Math.max(0, (sliceP - 0.55) / 0.45))) * globalFade;

          slice.style.transform = `translate3d(${moveX}px, ${moveY}px, 0)`;
          slice.style.opacity = `${opacity}`;
          slice.style.filter = `blur(${(1 - opacity) * 4}px)`;
          content.style.transform = `scale(${stretch}, ${squish})`;
          content.style.opacity = `${opacity}`;
        });

        if (p < 1) {
          window.requestAnimationFrame(frame);
          return;
        }

        overlay.remove();
        section.remove();
      }

      window.requestAnimationFrame(frame);
    }

    document.querySelectorAll('.cta-read').forEach((cta) => {
      cta.addEventListener('click', (event) => {
        event.preventDefault();
        const section = (cta as HTMLElement).closest('.content-section') as HTMLElement | null;
        if (!section) return;
        vanishSection(section);
      });
    });

    // ─── Sequential spaghettification para o botão "Lançar ao Limbo" ────────────

    function spaghettifyElement(el: HTMLElement, bhX: number, bhY: number, duration: number): Promise<void> {
      return new Promise(resolve => {
        const rect = el.getBoundingClientRect();
        if (rect.width === 0 && rect.height === 0) { resolve(); return; }

        const clone = el.cloneNode(true) as HTMLElement;
        clone.style.cssText = [
          `position:fixed`,
          `left:${rect.left}px`,
          `top:${rect.top}px`,
          `width:${rect.width}px`,
          `height:${rect.height}px`,
          `margin:0`,
          `z-index:9999`,
          `pointer-events:none`,
          `transform-origin:left center`,
        ].join(';');
        document.body.appendChild(clone);
        el.style.visibility = 'hidden';

        // Vetor parte do lado direito do elemento em direção ao canto superior direito
        const rx = rect.right;
        const ry = rect.top + rect.height / 2;
        const dx = bhX - rx;
        const dy = bhY - ry;
        const len = Math.max(1, Math.sqrt(dx * dx + dy * dy));
        const nx = dx / len;
        const ny = dy / len;

        // Translate parte do centro do elemento
        const cx = rect.left + rect.width  / 2;
        const cy = rect.top  + rect.height / 2;
        const tdx = bhX - cx;
        const tdy = bhY - cy;

        const start = performance.now();

        function frame(now: number) {
          const p    = Math.min(1, (now - start) / duration);
          const ease = p * p * (3 - 2 * p); // smoothstep

          // Movimento constante em direção ao destino
          const mx = tdx * ease;
          const my = tdy * ease;

          // Distorção só começa a 70% do percurso
          const distP   = Math.max(0, (p - 0.7) / 0.3);
          const stretch = 1 + distP * distP * 8.0;
          const squish  = Math.max(0.02, 1 - distP * distP * 0.96);
          const skewX   = nx * ny * distP * distP * 1.2;

          const scaleX = squish + Math.abs(nx) * (stretch - squish);
          const scaleY = squish + Math.abs(ny) * (stretch - squish);

          // Fade só nos últimos 20%
          const opacity = Math.max(0, 1 - Math.max(0, (p - 0.8) / 0.2));

          clone.style.transform = `translate(${mx}px,${my}px) matrix(${scaleX},0,${skewX},${scaleY},0,0)`;
          clone.style.opacity   = String(opacity);

          if (p < 1) { requestAnimationFrame(frame); }
          else       { clone.remove(); resolve(); }
        }

        requestAnimationFrame(frame);
      });
    }

    function collapseShell(section: HTMLElement, bhX: number, bhY: number): Promise<void> {
      return new Promise(resolve => {
        const rect = section.getBoundingClientRect();
        const cx = rect.left + rect.width  / 2;
        const cy = rect.top  + rect.height / 2;
        const dx = bhX - cx;
        const dy = bhY - cy;
        const start    = performance.now();
        const duration = 500;

        section.style.transition      = 'none';
        section.style.transformOrigin = 'left center';

        const len = Math.max(1, Math.sqrt(dx * dx + dy * dy));
        const nx  = dx / len;
        const ny  = dy / len;

        function frame(now: number) {
          const p    = Math.min(1, (now - start) / duration);
          const ease = p * p * (3 - 2 * p); // smoothstep

          const moveX = dx * ease;
          const moveY = dy * ease;

          // Distorção só após 70%
          const distP   = Math.max(0, (p - 0.7) / 0.3);
          const stretch = 1 + distP * distP * 8.0;
          const squish  = Math.max(0.01, 1 - distP * distP * 0.96);
          const skewX   = nx * ny * distP * distP * 1.2;

          const scaleX  = squish + Math.abs(nx) * (stretch - squish);
          const scaleY  = squish + Math.abs(ny) * (stretch - squish);

          const opacity = Math.max(0, 1 - Math.max(0, (p - 0.8) / 0.2));
          const borderA = Math.max(0, 1 - p * 2.5);

          section.style.transform   = `translate(${moveX}px,${moveY}px) matrix(${scaleX},0,${skewX},${scaleY},0,0)`;
          section.style.opacity     = String(opacity);
          section.style.borderColor = `rgba(0,212,232,${borderA})`;

          if (p < 1) { requestAnimationFrame(frame); }
          else       { section.remove(); resolve(); }
        }

        requestAnimationFrame(frame);
      });
    }

    function sleep(ms: number) {
      return new Promise<void>(r => setTimeout(r, ms));
    }

    async function vanishSectionSequential(section: HTMLElement) {
      if (section.classList.contains('is-vanishing')) return;
      section.classList.add('is-vanishing');
      section.style.pointerEvents = 'none';

      const bhX = window.innerWidth;
      const bhY = 0;

      // 1 — botão lançar ao limbo
      const limboBtn = section.querySelector('.limbo-cta') as HTMLElement | null;
      if (limboBtn) await spaghettifyElement(limboBtn, bhX, bhY, 420);

      await sleep(80);

      // 2 — parágrafo + "Continuar leitura"
      const sectionText = section.querySelector('.section-text') as HTMLElement | null;
      if (sectionText) await spaghettifyElement(sectionText, bhX, bhY, 520);

      await sleep(80);

      // 3 — ícones das redes sociais + copiar link
      const postActions = section.querySelector('.post-actions') as HTMLElement | null;
      if (postActions) await spaghettifyElement(postActions, bhX, bhY, 420);

      await sleep(80);

      // 4 — título + por: autor + tema
      const sectionInfo = section.querySelector('.section-info') as HTMLElement | null;
      if (sectionInfo) await spaghettifyElement(sectionInfo, bhX, bhY, 500);

      await sleep(80);

      // 5 — imagem
      const sectionImage = section.querySelector('.section-image') as HTMLElement | null;
      if (sectionImage) await spaghettifyElement(sectionImage, bhX, bhY, 560);

      await sleep(60);

      // 6 — bordas da seção colapsam e são sugadas
      await collapseShell(section, bhX, bhY);
    }

    document.querySelectorAll('.limbo-cta').forEach((cta) => {
      cta.addEventListener('click', (event) => {
        event.preventDefault();
        const section = (cta as HTMLElement).closest('.content-section') as HTMLElement | null;
        if (!section) return;
        vanishSectionSequential(section);
      });
    });

    // ─── Indicador de progresso de leitura ───────────────────────────────────

    const PROGRESS_CIRCUMFERENCE = 43.98;

    function applyReadingProgress(section: HTMLElement, percent: number) {
      const fill = section.querySelector('.progress-ring-fill') as SVGCircleElement | null;
      const text = section.querySelector('.progress-text') as HTMLElement | null;
      if (!fill || !text) return;

      const clamped = Math.min(100, Math.max(0, percent));
      const offset = PROGRESS_CIRCUMFERENCE * (1 - clamped / 100);
      fill.style.strokeDashoffset = String(offset);
      text.textContent = `${Math.round(clamped)}% lido`;

      const done = clamped >= 100;
      fill.classList.toggle('completed', done);
      text.classList.toggle('completed', done);
    }

    function loadReadingProgress() {
      document.querySelectorAll<HTMLElement>('.content-section').forEach(section => {
        const id = section.getAttribute('data-section-id');
        if (!id) return;
        const saved = localStorage.getItem(`reading-progress-${id}`);
        if (saved !== null) {
          applyReadingProgress(section, parseFloat(saved));
        }
      });
    }

    // Expõe para que a página do post possa atualizar o progresso via:
    // window.setReadingProgress('section-1', 72)
    (window as any).setReadingProgress = function(sectionId: string, percent: number) {
      localStorage.setItem(`reading-progress-${sectionId}`, String(percent));
      const section = document.querySelector<HTMLElement>(
        `.content-section[data-section-id="${sectionId}"]`
      );
      if (section) applyReadingProgress(section, percent);
    };

    loadReadingProgress();
  </script>
