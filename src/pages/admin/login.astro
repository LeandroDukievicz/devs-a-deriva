---
import Base from '../../layouts/Base.astro';
import StarBackground from '../../components/StarBackground.astro';
---

<Base title="Admin Login · Devs à Deriva">
  <StarBackground />

  <main class="admin-login-shell">
    <section class="admin-login-card">
      <p class="admin-login-kicker">&gt;_ acesso restrito</p>
      <h1 class="admin-login-title">Login do Dashboard</h1>
      <p class="admin-login-copy">
        Esta rota já está reservada para o painel administrativo. A tela de autenticação
        ainda será implementada.
      </p>
      <a href="/" class="admin-login-cta">Voltar para o blog</a>
    </section>
  </main>
</Base>

<style>
  .admin-login-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 96px 20px 32px;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .admin-login-card {
    width: min(100%, 480px);
    padding: 32px 28px;
    border: 1px solid var(--color-star-18);
    border-radius: 18px;
    background: var(--color-bg-88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow:
      0 0 24px var(--color-star-10),
      inset 0 0 0 1px var(--color-star-08);
  }

  .admin-login-kicker,
  .admin-login-title,
  .admin-login-copy,
  .admin-login-cta {
    font-family: monospace;
  }

  .admin-login-kicker {
    margin: 0 0 12px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.68rem;
  }

  .admin-login-title {
    margin: 0 0 16px;
    color: var(--color-star);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: clamp(1.2rem, 3vw, 1.6rem);
  }

  .admin-login-copy {
    margin: 0;
    color: var(--color-text);
    line-height: 1.7;
    font-size: 0.84rem;
  }

  .admin-login-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    margin-top: 24px;
    padding: 0 22px;
    border-radius: 999px;
    border: 1px outset var(--color-star);
    color: var(--color-star);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.68rem;
    transition:
      color 0.22s ease,
      border-color 0.22s ease,
      background 0.22s ease,
      box-shadow 0.22s ease,
      transform 0.22s ease;
  }

  .admin-login-cta:hover,
  .admin-login-cta:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-08);
    box-shadow: 0 0 14px var(--color-accent-20);
    transform: translateY(-1px);
  }
</style>
