---
import Base from '../layouts/Base.astro';
import BlackHole from '../components/BlackHole.astro';

const dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL ?? 'http://localhost:3000';
---

<Base title="Devs · Devs à Deriva">
  <main id="main-content" class="devs-page">
    <BlackHole bhX={0.5} bhY={0.5} bhScale={0.35} />

    <div class="cards-overlay" id="cards-overlay" data-dashboard={dashboardUrl}></div>

    <!-- Popup único, reposicionado pelo JS -->
    <div id="dev-popup" class="dev-popup" aria-hidden="true">
      <h3 class="dev-popup__name"></h3>
      <span class="dev-popup__role"></span>
      <p class="dev-popup__bio"></p>
    </div>
  </main>
</Base>

<style>
  .devs-page {
    position: fixed;
    inset: 0;
  }

  .devs-page > :global(#bh-container) {
    width: 100vw;
    height: 100vh;
  }

  .cards-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Âncora animada pelo JS — :global porque é criada dinamicamente */
  :global(.dev-card-anchor) {
    position: absolute;
    top: 0;
    left: 0;
    width: 91px;
    height: 91px;
    will-change: transform, opacity;
  }

  /* ── Círculo — :global porque os elementos são criados via JS ── */
  :global(.dev-card) {
    pointer-events: auto;
    cursor: pointer;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-bg-88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  :global(.dev-card--star) {
    border: 1px solid var(--color-star-25);
    box-shadow: 0 0 18px var(--color-star-10), inset 0 0 18px var(--color-star-05);
  }

  :global(.dev-card--accent) {
    border: 1px solid var(--color-accent-20);
    box-shadow: 0 0 18px var(--color-accent-08), inset 0 0 18px var(--color-accent-06);
  }

  :global(.dev-card:hover) { transform: scale(1.1); }

  :global(.dev-card--star:hover) {
    border-color: var(--color-star-45);
    box-shadow: 0 0 32px var(--color-star-22), inset 0 0 24px var(--color-star-10);
  }

  :global(.dev-card--accent:hover) {
    border-color: var(--color-accent-40);
    box-shadow: 0 0 32px var(--color-accent-16), inset 0 0 24px var(--color-accent-08);
  }

  /* ── Foto ──────────────────────────────────────────────────── */
  :global(.dev-card__photo) {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  /* ── Popup ─────────────────────────────────────────────────── */
  .dev-popup {
    position: fixed;
    z-index: 100;
    width: 220px;
    padding: 18px 20px;
    border-radius: 12px;
    background: var(--color-bg-90);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    display: flex;
    flex-direction: column;
    gap: 5px;
    pointer-events: none;

    opacity: 0;
    transform: translateY(-50%) translateX(6px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .dev-popup.is-visible {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .dev-popup.accent-star {
    border: 1px solid var(--color-star-22);
    box-shadow: 0 0 28px var(--color-star-10);
  }

  .dev-popup.accent-accent {
    border: 1px solid var(--color-accent-18);
    box-shadow: 0 0 28px var(--color-accent-08);
  }

  .dev-popup__name {
    margin: 0;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }

  .dev-popup__role {
    font-family: monospace;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    opacity: 0.8;
  }

  .dev-popup.accent-star   .dev-popup__role { color: var(--color-star); }
  .dev-popup.accent-accent .dev-popup__role { color: var(--color-accent); }

  .dev-popup__bio {
    margin: 6px 0 0;
    font-size: 0.72rem;
    color: var(--color-text);
    opacity: 0.55;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .cards-overlay {
      inset: 56px 0 0;
    }

    :global(.dev-card-anchor) { width: 70px; height: 70px; }

    .dev-popup {
      width: min(calc(100vw - 32px), 320px);
      padding: 16px 18px;
      transform: translateX(-50%) translateY(12px);
    }

    .dev-popup.is-visible {
      transform: translateX(-50%) translateY(0);
    }

    .dev-popup__name {
      font-size: 0.92rem;
    }

    .dev-popup__role {
      font-size: 0.68rem;
    }

    .dev-popup__bio {
      font-size: 0.78rem;
      line-height: 1.6;
    }
  }
</style>

<script>
// ── Helpers ────────────────────────────────────────────────────
function githubAvatar(githubUrl: string | null): string | null {
  if (!githubUrl) return null;
  try {
    const match = new URL(githubUrl).pathname.replace(/^\//, '').split('/')[0];
    return match ? `https://github.com/${match}.png?size=200` : null;
  } catch { return null; }
}

function initials(name: string): string {
  return name.split(' ').slice(0, 2).map(w => w[0]).join('').toUpperCase();
}

// ── Busca devs do dashboard e cria os cards ─────────────────────
const overlay      = document.getElementById('cards-overlay') as HTMLElement;
const dashboardUrl = overlay?.dataset.dashboard ?? 'http://localhost:3000';

interface Dev { name: string; role: string; bio: string; photoUrl: string | null; githubUrl: string | null; isOwner: boolean }

async function loadDevs() {
  let devs: Dev[] = [];
  try {
    const res = await fetch(`${dashboardUrl}/api/devs`);
    if (res.ok) {
      const json = await res.json() as { devs: Dev[] };
      devs = json.devs ?? [];
    }
  } catch {
    devs = [];
  }

  if (devs.length === 0) return;

  devs.forEach((dev, i) => {
    const accent  = i % 2 === 0 ? 'star' : 'accent';
    // Prioridade: foto do OAuth (Gmail/Google) → avatar do GitHub → iniciais
    const photoUrl = dev.photoUrl ?? githubAvatar(dev.githubUrl);

    const anchor  = document.createElement('div');
    anchor.className = 'dev-card-anchor';
    anchor.dataset.name   = dev.name;
    anchor.dataset.role   = dev.role;
    anchor.dataset.bio    = dev.bio;
    anchor.dataset.accent = accent;

    const card = document.createElement('div');
    card.className = `dev-card dev-card--${accent}`;

    if (photoUrl) {
      const img = document.createElement('img');
      img.className   = 'dev-card__photo';
      img.src         = photoUrl;
      img.alt         = dev.name;
      img.draggable   = false;
      img.onerror     = () => {
        img.remove();
        card.textContent = initials(dev.name);
        card.style.fontSize = '1.1rem';
      };
      card.appendChild(img);
    } else {
      card.textContent = initials(dev.name);
      card.style.fontSize = '1.1rem';
    }

    anchor.appendChild(card);
    overlay.appendChild(anchor);
  });

  initAnimation();
}

// ── Animação ────────────────────────────────────────────────────
const FADE_ZONE_MULT  = 9;    // fade começa a 9× o raio do BH
const ACCEL_THRESHOLD = 0.35; // opacidade abaixo disso → aceleração gravitacional
const ACCEL_PEAK      = 28;   // multiplicador máximo de velocidade no momento da sucção

function isMobile() {
  return window.innerWidth <= 600;
}

function getCardHalfSize() {
  return isMobile() ? 35 : 45.5;
}

function getSafeBounds() {
  return {
    top: isMobile() ? 88 : 24,
    right: 20,
    bottom: isMobile() ? 24 : 20,
    left: 20,
  };
}

function getMaxRadiusForAngle(
  angle: number,
  bh: { x: number; y: number; W: number; H: number },
  halfSize: number
) {
  const safe = getSafeBounds();
  const cos = Math.cos(angle);
  const sin = Math.sin(angle);
  const limits: number[] = [];

  if (cos > 0) limits.push((bh.W - safe.right - halfSize - bh.x) / cos);
  if (cos < 0) limits.push((safe.left + halfSize - bh.x) / cos);
  if (sin > 0) limits.push((bh.H - safe.bottom - halfSize - bh.y) / sin);
  if (sin < 0) limits.push((safe.top + halfSize - bh.y) / sin);

  return Math.max(0, ...limits.filter((value) => Number.isFinite(value) && value >= 0));
}

function getBH() {
  const W = window.innerWidth;
  const H = window.innerHeight;
  return { x: W / 2, y: H / 2, r: Math.min(W, H) * 0.22 * 0.35, W, H };
}

/** Retorna o multiplicador de aceleração com base na opacidade atual */
function pullFactor(opacity: number): number {
  if (opacity > ACCEL_THRESHOLD) return 1;
  const t = 1 - opacity / ACCEL_THRESHOLD; // 0→1 conforme opacidade cai para 0
  return 1 + t * t * (ACCEL_PEAK - 1);
}

function spawnAtEdge(d: CardData) {
  const { x: bhX, y: bhY, W, H } = getBH();
  const half = getCardHalfSize();
  const safe = getSafeBounds();
  const edge = Math.floor(Math.random() * 4);
  let sx: number, sy: number;

  switch (edge) {
    case 0: sx = safe.left + Math.random() * (W - safe.left - safe.right); sy = safe.top - half * 2; break;
    case 1: sx = W + half * 2; sy = safe.top + Math.random() * (H - safe.top - safe.bottom); break;
    case 2: sx = safe.left + Math.random() * (W - safe.left - safe.right); sy = H + half * 2; break;
    default: sx = safe.left - half * 2; sy = safe.top + Math.random() * (H - safe.top - safe.bottom); break;
  }

  const dx = sx - bhX;
  const dy = sy - bhY;
  d.angle  = Math.atan2(dy, dx);
  d.radius = Math.sqrt(dx * dx + dy * dy);
  d.opacity = 0;
}

interface CardData {
  el: HTMLElement;
  angle: number;
  radius: number;
  orbitSpeed: number;
  baseDecayRate: number;
  opacity: number;
  state: 'orbiting' | 'spawning';
  paused: boolean;
}

/** Posiciona o card em coordenadas aleatórias dentro da tela, fora do BH */
function initOnScreen(d: CardData) {
  const { x: bhX, y: bhY, r: bhR, W, H } = getBH();
  const halfSize = getCardHalfSize();
  const safe = getSafeBounds();
  const margin   = halfSize + 10;
  const minDist  = bhR * 3.5; // não começa colado ao BH
  let sx: number, sy: number, dist: number;

  // Tenta até achar ponto fora do BH e dentro da tela
  do {
    sx = safe.left + margin + Math.random() * (W - safe.left - safe.right - margin * 2);
    sy = safe.top + margin + Math.random() * (H - safe.top - safe.bottom - margin * 2);
    dist = Math.sqrt((sx - bhX) ** 2 + (sy - bhY) ** 2);
  } while (dist < minDist);

  const dx = sx - bhX;
  const dy = sy - bhY;
  d.angle   = Math.atan2(dy, dx);
  d.radius  = dist;
  d.opacity = 1;
  d.state   = 'orbiting';
}

function initAnimation() {
const popup   = document.getElementById('dev-popup') as HTMLElement;
const anchors = Array.from(document.querySelectorAll<HTMLElement>('.dev-card-anchor'));
let activeAnchor: HTMLElement | null = null;

// ── Popup helpers ─────────────────────────────────────────────
function showPopup(anchor: HTMLElement) {
  const { name, role, bio, accent } = anchor.dataset;
  popup.querySelector('.dev-popup__name')!.textContent = name ?? '';
  popup.querySelector('.dev-popup__role')!.textContent = role ?? '';
  popup.querySelector('.dev-popup__bio')!.textContent  = bio  ?? '';

  popup.classList.remove('accent-star', 'accent-accent');
  popup.classList.add(`accent-${accent}`);

  const rect       = anchor.getBoundingClientRect();
  const gap        = 16;

  if (isMobile()) {
    popup.style.left = '50%';
    popup.style.top = 'auto';
    popup.style.bottom = '16px';
  } else {
    const popupW     = 220;
    const spaceRight = window.innerWidth - rect.right;
    popup.style.bottom = 'auto';
    popup.style.left = spaceRight >= popupW + gap
      ? `${rect.right + gap}px`
      : `${rect.left - popupW - gap}px`;
    popup.style.top = `${rect.top + rect.height / 2}px`;
  }

  popup.classList.add('is-visible');
  popup.setAttribute('aria-hidden', 'false');
  activeAnchor = anchor;
}

function hidePopup() {
  popup.classList.remove('is-visible');
  popup.setAttribute('aria-hidden', 'true');
  activeAnchor = null;
}

// ── Dados de animação ─────────────────────────────────────────
const data: CardData[] = anchors.map((el, i) => {
  const card = el.querySelector<HTMLElement>('.dev-card')!;

  card.addEventListener('mouseenter', () => {
    if (isMobile()) return;
    const d = data.find(d => d.el === el);
    if (d) d.paused = true;
    showPopup(el);
  });
  card.addEventListener('mouseleave', () => {
    if (isMobile()) return;
    const d = data.find(d => d.el === el);
    if (d) d.paused = false;
    hidePopup();
  });
  card.addEventListener('click', () => {
    if (!isMobile()) return;

    const d = data.find(d => d.el === el);
    if (!d) return;

    if (activeAnchor === el) {
      d.paused = false;
      hidePopup();
      return;
    }

    data.forEach((item) => {
      item.paused = item.el === el;
    });
    showPopup(el);
  });

  const d: CardData = {
    el,
    angle: 0,
    radius: 0,
    orbitSpeed:    0.00018 + Math.random() * 0.00008,
    baseDecayRate: 0.00012 + Math.random() * 0.00004,
    opacity: 1,
    state: 'orbiting',
    paused: false,
  };

  initOnScreen(d);
  return d;
});

// ── Loop de animação ──────────────────────────────────────────
function tick() {
  const bh = getBH();

  for (const d of data) {
    if (d.paused) continue;

    // ── Movimento (sempre ativo, inclusive durante spawning) ──
    const factor = pullFactor(d.opacity);
    d.angle  += d.orbitSpeed  * factor;
    d.radius -= d.radius * d.baseDecayRate * factor;
    const halfSize = getCardHalfSize();
    const maxRadius = getMaxRadiusForAngle(d.angle, bh, halfSize);
    d.radius = Math.min(d.radius, maxRadius);

    const x = bh.x + Math.cos(d.angle) * d.radius;
    const y = bh.y + Math.sin(d.angle) * d.radius;
    d.el.style.transform = `translate(${x - halfSize}px, ${y - halfSize}px)`;

    // ── Fade-in ao nascer na borda ────────────────────────────
    if (d.state === 'spawning') {
      d.opacity = Math.min(1, d.opacity + 0.022);
      d.el.style.opacity = String(d.opacity);
      if (d.opacity >= 1) d.state = 'orbiting';
      continue;
    }

    // ── Fade-out por proximidade ao BH ────────────────────────
    const fadeZone = bh.r * FADE_ZONE_MULT;
    if (d.radius < fadeZone) {
      d.opacity = Math.max(0, (d.radius - bh.r) / (fadeZone - bh.r));
    } else {
      d.opacity = 1;
    }
    d.el.style.opacity = String(d.opacity);

    // ── Sugado: ressurge imediatamente em outra borda ─────────
    if (d.radius <= bh.r * 1.05) {
      spawnAtEdge(d);   // reposiciona na borda (opacity já vai para 0)
      d.state = 'spawning';
    }
  }

  requestAnimationFrame(tick);
}

window.addEventListener('resize', () => {
  if (activeAnchor) showPopup(activeAnchor);
});

document.addEventListener('click', (event) => {
  if (!isMobile()) return;
  const target = event.target as Node;
  if (popup.contains(target)) return;

  const clickedAnchor = anchors.some((anchor) => anchor.contains(target));
  if (clickedAnchor) return;

  data.forEach((item) => {
    item.paused = false;
  });
  hidePopup();
});

tick();
} // end initAnimation

loadDevs();
</script>
