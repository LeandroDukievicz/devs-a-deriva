---
import Base from '../../layouts/Base.astro';
import StarBackground from '../../components/StarBackground.astro';
import Comments from '../../components/Comments.astro';
import { fetchPosts, type Post } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await fetchPosts();
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: { post, nextPost: posts[index + 1] ?? posts[0] },
  }));
}

const { post, nextPost } = Astro.props as { post: Post; nextPost: Post };
const DASHBOARD_URL = import.meta.env.PUBLIC_DASHBOARD_URL ?? 'http://localhost:3000';
const SITE = 'https://devsaderiva.com.br';
const postImages: Record<string, string> = {
  'portas-que-nao-levam-a-lugar-nenhum': '/home-portas-que-nao-levam-a-lugar-nenhum.png',
  'navegando-em-mares-que-inventei': '/home-navegando-em-mares-que-inventei.png',
  'cartas-para-meu-eu-do-futuro': '/home-cartas-para-meu-eu-do-futuro.png',
  'o-estado-atual-da-ia-no-desenvolvimento': '/home-o-estado-atual-da-ia-no-desenvolvimento.png',
  'typescript-strict-mode-vale-a-pena': '/home-typescript-strict-mode-vale-a-pena.png',
};
const categoryImages: Record<string, string> = {
  aleatoriedades: '/aleatoriedades-astronaut-body.webp',
  carreira: '/carreira-profissional-astronaut-body.webp',
  livros: '/livros-astronaut.webp',
  musica: '/musica-astronaut.webp',
  noticias: '/noticias-astronaut.webp',
  tech: '/tech-astronaut.webp',
};
const postHeroImage = post.thumbUrl ?? postImages[post.slug] ?? categoryImages[post.categorySlug] ?? '/logo-high-color.webp';
const postHeroImageAbsolute = postHeroImage.startsWith('http') ? postHeroImage : `${SITE}${postHeroImage}`;
const categoryBackHref = `/categorias/${post.categorySlug}`;
const categoryNextHref = `/posts/${nextPost.slug}?from=category`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  image: postHeroImageAbsolute,
  author: {
    '@type': 'Person',
    name: post.author.name,
    ...(post.author.socialLinks.linkedin ? { url: post.author.socialLinks.linkedin } : {}),
  },
  publisher: {
    '@type': 'Organization',
    name: 'Devs à Deriva',
    logo: {
      '@type': 'ImageObject',
      url: `${SITE}/logo-high-color.webp`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE}/posts/${post.slug}`,
  },
  inLanguage: 'pt-BR',
  keywords: post.category,
};
---

<Base
  title={`${post.title} · Devs à Deriva`}
  description={post.excerpt}
  ogImage={postHeroImageAbsolute}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>
  <StarBackground />

  <article id="main-content" class="post-page" data-post-slug={post.slug} data-dashboard-url={DASHBOARD_URL}>
    <header class="post-header">
      <div class="post-header-main">
        <div class="post-header-copy">
          <a
            href={categoryBackHref}
            class="post-back"
            data-home-href="/"
            data-home-label="Home"
            data-category-href={categoryBackHref}
            data-category-label={post.category}
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            <span class="post-back-label">{post.category}</span>
          </a>

          <h1 class="post-title">{post.title}</h1>
          <p class="post-excerpt">{post.excerpt}</p>
          <div class="post-theme-row" data-home-only="true">
            <p class="post-theme">Tema: {post.category}</p>
            <div class="post-reading-time post-reading-time-mobile">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              {post.readTime} de leitura
              <span class="post-reading-progress" data-progress-label>0% lido</span>
            </div>
          </div>

          <div class="post-meta">
            <div class="post-author">
              <img
                class="post-author-avatar"
                src={post.author.photo}
                alt={`Foto de ${post.author.name}`}
                loading="eager"
                decoding="async"
              />
              <div class="post-author-copy">
                <span class="post-author-name">{post.author.name}</span>
                <span class="post-author-role">{post.author.role}</span>
              </div>
            </div>

            <span class="post-meta-separator" aria-hidden="true"></span>

            <div class="post-reading-time">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              {post.readTime} de leitura
              <span class="post-reading-progress" data-progress-label>0% lido</span>
            </div>
          </div>
        </div>

        <figure class="post-hero">
          <img src={postHeroImage} alt={post.title} class="post-hero-image" />
        </figure>
      </div>
    </header>

    <div class="post-divider"></div>

    <div class="post-body" set:html={post.contentHtml}></div>

    <Comments postSlug={post.slug} />

    <div class="newsletter-block">
      <div class="newsletter-content">
        <span class="newsletter-tag">&gt;_ Newsletter</span>
        <h2 class="newsletter-title">E aí, gostou do conteúdo?</h2>
        <p class="newsletter-desc">Se quiser ficar por dentro dos novos posts, opiniões sem filtro e saber o que tá rolando no mundo tech, entra na lista. Sem spam, sem aquela encheção que faz você querer cancelar no segundo e-mail.</p>
      </div>
      <form class="newsletter-form" id="newsletter-form" novalidate>
        <input
          type="text"
          class="newsletter-honeypot"
          id="newsletter-website"
          name="website"
          autocomplete="off"
          tabindex="-1"
          aria-hidden="true"
        />
        <div class="newsletter-input-wrap">
          <input
            type="email"
            class="newsletter-input"
            id="newsletter-email"
            placeholder="seu@email.com"
            autocomplete="email"
            inputmode="email"
            maxlength="254"
            aria-label="Seu e-mail"
            required
          />
          <button type="submit" class="newsletter-btn" aria-label="Entrar na órbita">
            <span class="newsletter-btn-text">Entrar na órbita</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>
        <label class="newsletter-consent">
          <input type="checkbox" id="newsletter-consent" required />
          <span class="newsletter-check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </span>
          <span>Autorizo o uso deste e-mail para receber a newsletter e sei que posso solicitar exclusão a qualquer momento.</span>
        </label>
        <p class="newsletter-status" id="newsletter-status" aria-live="polite"></p>
      </form>
      <div class="newsletter-overlay" id="newsletter-overlay" aria-live="polite" aria-hidden="true">
        <span class="newsletter-overlay-grid" aria-hidden="true"></span>
        <div class="newsletter-overlay-badge">
          <span class="newsletter-overlay-badge-dot" aria-hidden="true"></span>
          <span>SINAL RECEBIDO</span>
        </div>
        <div class="newsletter-overlay-copy">
          <span class="newsletter-overlay-kicker">&gt; transmissão confirmada</span>
          <strong>Houston, temos um novo assinante!</strong>
        </div>
      </div>
    </div>

    <footer class="post-footer">
      <a
        href={categoryBackHref}
        class="post-back-footer"
        data-home-href="/"
        data-home-label="Voltar para Home"
        data-category-href={categoryBackHref}
        data-category-label={`Voltar para ${post.category}`}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        <span class="post-back-footer-label">Voltar para {post.category}</span>
      </a>

      <a
        href={categoryNextHref}
        class="post-next-footer"
        data-home-href={`/posts/${nextPost.slug}?from=home`}
        data-home-label="Prox Post"
        data-home-title={nextPost.title}
        data-category-href={categoryNextHref}
        data-category-label="Prox Post"
        data-category-title={nextPost.title}
      >
        <span class="post-next-label">Prox Post</span>
        <span class="post-next-title">{nextPost.title}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    </footer>
  </article>
</Base>

<style>
  .post-page {
    position: relative;
    z-index: 10;
    width: 85%;
    margin: 0 auto;
    padding: 100px 0 80px;
  }

  .post-header {
    opacity: 0;
    animation: fade-up 0.55s ease 0.1s forwards;
  }

  .post-header-main {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
    gap: 28px;
    align-items: start;
  }

  .post-header-copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    width: fit-content;
    max-width: 100%;
    transition: opacity 0.2s ease;
  }

  .post-back:hover { opacity: 0.7; }

  .post-back-label {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .post-title {
    margin: 0;
    font-family: monospace;
    font-size: clamp(1.3rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-star);
    text-shadow: 0 0 30px var(--color-star-25);
    letter-spacing: 0.02em;
  }

  .post-excerpt {
    margin: 0;
    font-family: monospace;
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--color-star);
    opacity: 0.55;
    max-width: 520px;
  }

  .post-theme-row {
    display: none;
  }

  .post-theme {
    margin: -4px 0 0;
    font-family: monospace;
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.8;
    overflow-wrap: anywhere;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: monospace;
    font-size: 0.62rem;
    color: var(--color-star);
    opacity: 0.45;
    letter-spacing: 0.06em;
    flex-wrap: wrap;
  }

  .post-author {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .post-author-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--color-star-25);
    box-shadow: 0 0 18px var(--color-star-10);
    flex-shrink: 0;
  }

  .post-author-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    overflow: hidden;
  }

  .post-author-name,
  .post-author-role {
    display: block;
    line-height: 1.3;
  }

  .post-author-name {
    color: var(--color-star);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .post-author-role {
    font-size: 0.58rem;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }

  .post-meta-separator {
    width: 1px;
    height: 28px;
    background: linear-gradient(to bottom, transparent, var(--color-star), transparent);
    opacity: 0.25;
  }

  .post-reading-time {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .post-reading-progress {
    color: var(--color-accent);
    font-weight: 700;
  }

  .post-reading-progress.completed {
    color: var(--color-star);
    text-shadow: 0 0 12px var(--color-star-25);
  }

  .post-reading-time-mobile {
    display: none;
  }

  .post-divider {
    margin: 32px 0;
    height: 1px;
    background: linear-gradient(to right, var(--color-accent), var(--color-star), transparent);
    opacity: 0.3;
    animation: fade-up 0.55s ease 0.2s both;
  }

  .post-hero {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--color-star-18);
    background: linear-gradient(135deg, var(--color-star-08), transparent 60%);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.28);
    animation: fade-up 0.55s ease 0.25s both;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-hero-image {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: center;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 24px;
    animation: fade-up 0.55s ease 0.3s both;
  }

  .post-body :global(p),
  .post-body :global(li),
  .post-body :global(blockquote) {
    margin: 0;
    font-family: monospace;
    font-size: 0.88rem;
    line-height: 1.9;
    color: var(--color-text);
    opacity: 0.85;
  }

  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    margin: 10px 0 -6px;
    font-family: monospace;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-star);
    letter-spacing: 0.04em;
  }

  .post-body :global(h2) {
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
  }

  .post-body :global(h3),
  .post-body :global(h4) {
    font-size: 0.98rem;
  }

  .post-body :global(blockquote) {
    padding: 14px 18px;
    border-left: 2px solid var(--color-accent);
    background: var(--color-star-05);
  }

  .post-body :global(ul) {
    margin: 0;
    padding-left: 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .post-body :global(hr) {
    width: 100%;
    height: 1px;
    margin: 4px 0;
    border: 0;
    background: linear-gradient(to right, transparent, var(--color-star-25), transparent);
  }

  .post-body :global(.post-content-image) {
    display: flex;
    justify-content: center;
    margin: 4px 0;
  }

  .post-body :global(.post-content-image img) {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 680px;
    border-radius: 14px;
    object-fit: contain;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-40);
  }

  .post-body :global(code) {
    padding: 2px 5px;
    border: 1px solid var(--color-star-16);
    border-radius: 4px;
    background: var(--color-star-05);
    color: var(--color-star);
  }

  .newsletter-block {
    margin-top: 72px;
    padding: 40px;
    border: 1px solid var(--color-star-22);
    border-radius: 12px;
    background: linear-gradient(135deg, var(--color-star-05) 0%, transparent 60%);
    display: flex;
    gap: 48px;
    align-items: center;
    animation: fade-up 0.55s ease 0.35s both;
    position: relative;
    overflow: hidden;
    transition: border-color 0.28s ease, box-shadow 0.28s ease, background 0.28s ease;
  }

  .newsletter-block::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 28%, var(--color-accent-12), transparent 32%),
      radial-gradient(circle at 76% 72%, var(--color-star-10), transparent 30%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .newsletter-block.is-confirmed {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent-12), 0 18px 42px rgba(0, 0, 0, 0.24);
    background: linear-gradient(135deg, var(--color-star-08) 0%, transparent 60%);
  }

  .newsletter-block.is-confirmed::after {
    opacity: 1;
    animation: newsletter-overlay-pulse 2.4s ease both;
  }

  .newsletter-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
    position: relative;
    z-index: 1;
    transition: opacity 0.18s ease, visibility 0.18s ease, transform 0.18s ease;
  }

  .newsletter-tag {
    font-family: monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .newsletter-title {
    margin: 0;
    font-family: monospace;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 700;
    color: var(--color-star);
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  .newsletter-desc {
    margin: 0;
    font-family: monospace;
    font-size: 0.72rem;
    line-height: 1.7;
    color: var(--color-star);
    opacity: 0.55;
  }

  .newsletter-form {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
    position: relative;
    z-index: 1;
    transition: opacity 0.18s ease, visibility 0.18s ease, transform 0.18s ease;
  }

  .newsletter-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .newsletter-block.is-confirmed .newsletter-content,
  .newsletter-block.is-confirmed .newsletter-form {
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
  }

  .newsletter-input-wrap {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--color-star-40);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .newsletter-input-wrap:focus-within {
    border-color: var(--color-star);
    box-shadow: 0 0 14px var(--color-star-22);
  }

  .newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 12px 16px;
    font-family: monospace;
    font-size: 0.78rem;
    color: var(--color-text);
    letter-spacing: 0.04em;
    min-width: 0;
  }

  .newsletter-input::placeholder {
    color: var(--color-star);
    opacity: 0.3;
  }

  .newsletter-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 20px;
    background: var(--color-star-10);
    border: none;
    border-left: 1px solid var(--color-star-22);
    color: var(--color-star);
    font-family: monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .newsletter-btn:hover {
    background: var(--color-star-22);
    color: var(--color-accent);
  }

  .newsletter-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .newsletter-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: monospace;
    font-size: 0.6rem;
    line-height: 1.55;
    letter-spacing: 0.05em;
    color: var(--color-star);
    opacity: 0.5;
    cursor: pointer;
  }

  .newsletter-consent input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .newsletter-check {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    margin-top: 1px;
    border-radius: 4px;
    border: 1px solid var(--color-star-40);
    background:
      linear-gradient(135deg, var(--color-star-08), transparent),
      var(--color-star-05);
    color: var(--color-bg);
    box-shadow: inset 0 0 0 1px transparent;
    flex-shrink: 0;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .newsletter-check svg {
    width: 11px;
    height: 11px;
    opacity: 0;
    transform: scale(0.7);
    transition: opacity 0.16s ease, transform 0.16s ease;
  }

  .newsletter-consent:hover .newsletter-check {
    border-color: var(--color-star);
    box-shadow: 0 0 12px var(--color-star-18);
  }

  .newsletter-consent input:focus-visible + .newsletter-check {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .newsletter-consent input:checked + .newsletter-check {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-bg);
    box-shadow: 0 0 16px var(--color-accent-30);
    transform: translateY(-1px);
  }

  .newsletter-consent input:checked + .newsletter-check svg {
    opacity: 1;
    transform: scale(1);
  }

  .newsletter-consent input:not(:checked) + .newsletter-check {
    animation: newsletter-check-pulse 2.6s ease-in-out infinite;
  }

  @keyframes newsletter-check-pulse {
    0%, 100% {
      box-shadow: inset 0 0 0 1px transparent, 0 0 0 rgba(255, 0, 180, 0);
      transform: scale(1);
    }
    48% {
      box-shadow: inset 0 0 0 1px rgba(255, 0, 180, 0.2), 0 0 14px rgba(255, 0, 180, 0.36);
      transform: scale(1.05);
    }
  }

  @media (prefers-reduced-motion: reduce) {
