</style>

<script>
  import { validateAndNormalizeEmail } from '../../lib/newsletter-email';
  import {
    getLocalProgress,
    pushReadingProgress,
    renderReadingProgress,
    saveLocalProgress,
    syncReadingProgress,
  } from '../../lib/reading-progress-client';

  const resolvePostOrigin = () => {
    const fromParam = new URLSearchParams(window.location.search).get('from');
    if (fromParam === 'home' || fromParam === 'category') return fromParam;

    const storedOrigin = sessionStorage.getItem('post-nav-origin');
    if (storedOrigin === 'home' || storedOrigin === 'category') return storedOrigin;

    if (document.referrer) {
      const referrerUrl = new URL(document.referrer);
      if (referrerUrl.origin === window.location.origin) {
        if (referrerUrl.pathname === '/') return 'home';
        if (referrerUrl.pathname.startsWith('/categorias/')) return 'category';
      }
    }

    return 'category';
  };

  const applyPostNavigation = () => {
    const origin = resolvePostOrigin();
    const useHome = origin === 'home';

    const topBack = document.querySelector<HTMLAnchorElement>('.post-back');
    const topBackLabel = document.querySelector<HTMLElement>('.post-back-label');
    const footerBack = document.querySelector<HTMLAnchorElement>('.post-back-footer');
    const footerBackLabel = document.querySelector<HTMLElement>('.post-back-footer-label');
    const footerNext = document.querySelector<HTMLAnchorElement>('.post-next-footer');
    const footerNextLabel = document.querySelector<HTMLElement>('.post-next-label');
    const footerNextTitle = document.querySelector<HTMLElement>('.post-next-title');
    const postHeaderCopy = document.querySelector<HTMLElement>('.post-header-copy');
    const homeOnlyTheme = document.querySelector<HTMLElement>('[data-home-only="true"]');

    if (topBack) {
      topBack.href = useHome ? (topBack.dataset.homeHref ?? '/') : (topBack.dataset.categoryHref ?? '/');
    }

    if (topBackLabel) {
      topBackLabel.textContent = useHome
        ? (topBack?.dataset.homeLabel ?? 'Home')
        : (topBack?.dataset.categoryLabel ?? '');
    }

    if (footerBack) {
      footerBack.href = useHome ? (footerBack.dataset.homeHref ?? '/') : (footerBack.dataset.categoryHref ?? '/');
    }

    if (footerBackLabel) {
      footerBackLabel.textContent = useHome
        ? (footerBack?.dataset.homeLabel ?? 'Voltar para Home')
        : (footerBack?.dataset.categoryLabel ?? '');
    }

    if (footerNext) {
      footerNext.href = useHome ? (footerNext.dataset.homeHref ?? '/') : (footerNext.dataset.categoryHref ?? '/');
    }

    if (footerNextLabel) {
      footerNextLabel.textContent = useHome
        ? (footerNext?.dataset.homeLabel ?? 'Prox Post')
        : (footerNext?.dataset.categoryLabel ?? 'Prox Post');
    }

    if (footerNextTitle) {
      footerNextTitle.textContent = useHome
        ? (footerNext?.dataset.homeTitle ?? '')
        : (footerNext?.dataset.categoryTitle ?? '');
    }

    postHeaderCopy?.classList.toggle('is-home-origin', useHome);

    if (homeOnlyTheme) {
      homeOnlyTheme.style.display = useHome ? 'flex' : 'none';
    }
  };

  applyPostNavigation();

  const postPage = document.querySelector<HTMLElement>('.post-page[data-post-slug]');
  const postBody = document.querySelector<HTMLElement>('.post-body');
  const postSlug = postPage?.dataset.postSlug;
  const dashboardUrl = postPage?.dataset.dashboardUrl;
  let lastSentProgress = postSlug ? getLocalProgress(postSlug).progress : 0;
  let ticking = false;

  function calculateReadingProgress(): number {
    if (!postBody) return 0;

    const viewportMarker = window.scrollY + window.innerHeight * 0.72;
    const start = postBody.offsetTop;
    const end = postBody.offsetTop + postBody.offsetHeight;
    const distance = Math.max(1, end - start);

    return Math.min(100, Math.max(0, Math.round(((viewportMarker - start) / distance) * 100)));
  }

  function updateReadingProgress(sendToServer: boolean): void {
    if (!postPage || !postSlug) return;

    const progress = calculateReadingProgress();
    const completed = progress >= 90;
    const current = getLocalProgress(postSlug);
    const nextProgress = Math.max(current.progress, progress);

    if (nextProgress <= current.progress && current.completed) {
      renderReadingProgress(postPage, postSlug);
      return;
    }

    if (dashboardUrl && sendToServer && (nextProgress - lastSentProgress >= 5 || completed)) {
      lastSentProgress = nextProgress;
      void pushReadingProgress(dashboardUrl, postSlug, nextProgress, completed).then(() => {
        renderReadingProgress(postPage, postSlug);
      });
      return;
    }

    if (!dashboardUrl || nextProgress > current.progress || completed) {
      saveLocalProgress(postSlug, nextProgress, completed);
      renderReadingProgress(postPage, postSlug);
    }
  }

  if (postPage && postSlug) {
    renderReadingProgress(postPage, postSlug);

    if (dashboardUrl) {
      void syncReadingProgress(dashboardUrl, [postSlug]).then(() => {
        lastSentProgress = getLocalProgress(postSlug).progress;
        renderReadingProgress(postPage, postSlug);
        updateReadingProgress(false);
      });
    } else {
      updateReadingProgress(false);
    }

    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        ticking = false;
        updateReadingProgress(true);
      });
    }, { passive: true });

    window.addEventListener('resize', () => updateReadingProgress(false));
    window.addEventListener('pagehide', () => updateReadingProgress(true));
  }

  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const status = document.getElementById('newsletter-status') as HTMLElement | null;
  const input = document.getElementById('newsletter-email') as HTMLInputElement | null;
  const consent = document.getElementById('newsletter-consent') as HTMLInputElement | null;
  const honeypot = document.getElementById('newsletter-website') as HTMLInputElement | null;
  const newsletterBlock = document.querySelector<HTMLElement>('.newsletter-block');
  const overlay = document.getElementById('newsletter-overlay') as HTMLElement | null;
  const newsletterEndpoint = dashboardUrl ? `${dashboardUrl}/api/newsletter/subscribe` : '';
  const newsletterMountedAt = Date.now();
  let overlayTimeout: ReturnType<typeof window.setTimeout> | undefined;

  const showNewsletterOverlay = () => {
    if (!overlay || !newsletterBlock) return;

    newsletterBlock.classList.remove('is-confirmed');
    overlay.classList.remove('is-visible');
    void overlay.offsetWidth;

    newsletterBlock.classList.add('is-confirmed');
    overlay.classList.add('is-visible');
    overlay.setAttribute('aria-hidden', 'false');

    if (overlayTimeout) window.clearTimeout(overlayTimeout);
    overlayTimeout = window.setTimeout(() => {
      newsletterBlock.classList.remove('is-confirmed');
      overlay.classList.remove('is-visible');
      overlay.setAttribute('aria-hidden', 'true');
    }, 2400);
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!input || !status) return;

    const emailResult = validateAndNormalizeEmail(input.value);
    if (!emailResult.isValid) {
      status.textContent = '> e-mail inválido.';
      status.className = 'newsletter-status error';
      return;
    }

    if (!consent?.checked) {
      status.textContent = '> confirme o recebimento da newsletter.';
      status.className = 'newsletter-status error';
      return;
    }

    if (!newsletterEndpoint) {
      status.textContent = '> captação indisponível no momento.';
      status.className = 'newsletter-status error';
      return;
    }

    const btn = form.querySelector<HTMLButtonElement>('.newsletter-btn');
    if (btn) btn.disabled = true;
    status.textContent = '> enviando...';
    status.className = 'newsletter-status';

    try {
      const response = await fetch(newsletterEndpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: emailResult.normalizedEmail,
          originalEmail: emailResult.originalEmail,
          source: 'post_newsletter',
          postSlug,
          consent: true,
          consentText: 'Autorizo o uso deste e-mail para receber a newsletter e sei que posso solicitar exclusão a qualquer momento.',
          website: honeypot?.value ?? '',
          elapsedMs: Date.now() - newsletterMountedAt,
          pageUrl: window.location.href,
        }),
      });

      if (!response.ok && response.status >= 500) {
        throw new Error('Newsletter endpoint unavailable');
      }

      input.value = '';
      if (consent) consent.checked = false;
      status.textContent = '> se esse e-mail puder entrar na órbita, você receberá a confirmação.';
      status.className = 'newsletter-status success';
      showNewsletterOverlay();
    } catch {
      status.textContent = '> não foi possível registrar agora. tente novamente.';
      status.className = 'newsletter-status error';
    } finally {
      if (btn) btn.disabled = false;
    }
  });
</script>
