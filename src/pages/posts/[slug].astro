      linear-gradient(135deg, rgba(5, 9, 19, 0.96), rgba(7, 13, 26, 0.9)),
      radial-gradient(circle at top left, var(--color-accent-12), transparent 45%);
    border: 1px solid var(--color-accent-12);
    opacity: 0;
    transform: scale(0.98);
    pointer-events: none;
    transition: opacity 0.28s ease, transform 0.34s ease;
