      font-size: 1rem;
    }

    .newsletter-desc {
      font-size: 0.68rem;
    }

    .newsletter-input {
      padding: 14px 16px;
      font-size: 0.74rem;
    }

    .newsletter-btn {
      font-size: 0.64rem;
      letter-spacing: 0.08em;
    }

    .post-footer {
      flex-direction: column;
