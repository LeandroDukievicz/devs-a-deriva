---
import Navbar from '../components/Navbar.astro';
import StarBackground from '../components/StarBackground.astro';
import ThemeProvider from '../components/ThemeProvider.astro';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Manifesto · Devs à Deriva</title>
    <style>
      .astronauts-drift {
        position: fixed;
        width: 30vw;
        max-width: 340px;
        pointer-events: none;
        z-index: 1;
        animation: contorno-shift 4s ease-in-out infinite;
        will-change: transform, opacity;
      }

      @keyframes contorno-shift {
        0%, 100% {
          filter: invert(1)
                  drop-shadow(0 0 4px #00d4e8)
                  drop-shadow(0 0 10px rgba(0, 212, 232, 0.4));
        }
        50% {
          filter: invert(1)
                  drop-shadow(0 0 4px #e800d4)
                  drop-shadow(0 0 10px rgba(232, 0, 212, 0.4));
        }
      }
    </style>
    <link rel="icon" type="image/svg+xml" href="/helmet.svg" />
    <ThemeProvider />
  </head>
  <body class="m-0 p-0 overflow-x-hidden">
    <Navbar />
    <StarBackground />
    <img
      id="astronauts"
      src="/astronauts.svg"
      alt="Astronauts"
      class="astronauts-drift"
    />
  </body>
</html>

<script>
  const el = document.getElementById('astronauts') as HTMLImageElement;

  const W = () => window.innerWidth;
  const H = () => window.innerHeight;

  // Posição inicial aleatória
  let cx = W() * 0.2 + Math.random() * W() * 0.6;
  let cy = H() * 0.2 + Math.random() * H() * 0.6;

  // Velocidade inicial suave (px/frame a ~60fps)
  const SPEED = 0.4;
  let angle  = Math.random() * Math.PI * 2;
  let vx     = Math.cos(angle) * SPEED;
  let vy     = Math.sin(angle) * SPEED;

  // Rotação visual
  let rot  = 0;
  let rotV = (Math.random() - 0.5) * 0.02;

  // Perturbação de direção: muda levemente a cada ~3s
  let nudgeTimer = 0;

  // Teletransporte
  let teleportTimer = 1800 + Math.random() * 1800;
  let isFading = false;

  el.style.top  = '0';
  el.style.left = '0';
  el.style.transform = `translate(${cx}px, ${cy}px) rotate(${rot}deg)`;

  function nudgeDirection() {
    // Gira levemente o vetor de velocidade (não muda a magnitude)
    const delta = (Math.random() - 0.5) * 0.4; // rad
    const speed = Math.hypot(vx, vy);
    const dir   = Math.atan2(vy, vx) + delta;
    vx = Math.cos(dir) * speed;
    vy = Math.sin(dir) * speed;
  }

  function teleport() {
    if (isFading) return;
    isFading = true;
    el.style.transition = 'opacity 1s ease';
    el.style.opacity = '0';

    setTimeout(() => {
      const margin = 60;
      const w = el.offsetWidth  || 300;
      const h = el.offsetHeight || 200;
      cx = margin + Math.random() * (W() - w - margin * 2);
      cy = margin + Math.random() * (H() - h - margin * 2);

      // Nova direção aleatória ao reaparecer
      const dir = Math.random() * Math.PI * 2;
      vx = Math.cos(dir) * SPEED;
      vy = Math.sin(dir) * SPEED;

      el.style.transition = 'opacity 1.2s ease';
      el.style.opacity = '1';
      isFading = false;
    }, 1000);
  }

  function frame() {
    nudgeTimer++;
    teleportTimer--;

    // Perturbação suave de direção a cada ~3s
    if (nudgeTimer >= 180) {
      nudgeDirection();
      nudgeTimer = 0;
    }

    // Teletransporte ocasional
    if (teleportTimer <= 0) {
      teleport();
      teleportTimer = 1800 + Math.random() * 1800;
    }

    // Manter velocidade constante (sem aceleração)
    const speed = Math.hypot(vx, vy);
    if (speed > 0) {
      vx = (vx / speed) * SPEED;
      vy = (vy / speed) * SPEED;
    }

    cx += vx;
    cy += vy;

    // Reflexão suave nas bordas
    const w = el.offsetWidth  || 300;
    const h = el.offsetHeight || 200;
    const margin = 20;

    if (cx < margin)              { cx = margin;              vx = Math.abs(vx); }
    if (cx > W() - w - margin)    { cx = W() - w - margin;    vx = -Math.abs(vx); }
    if (cy < margin)              { cy = margin;              vy = Math.abs(vy); }
    if (cy > H() - h - margin)    { cy = H() - h - margin;    vy = -Math.abs(vy); }

    // Rotação visual contínua e lenta
    rotV += (Math.random() - 0.5) * 0.001;
    rotV  = Math.max(-0.04, Math.min(0.04, rotV));
    rot  += rotV;

    el.style.transform = `translate(${cx}px, ${cy}px) rotate(${rot}deg)`;

    requestAnimationFrame(frame);
  }

  requestAnimationFrame(frame);
</script>
