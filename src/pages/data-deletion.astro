---
import Base from '../layouts/Base.astro';
import StarBackground from '../components/StarBackground.astro';
---

<Base title="Data Deletion · Devs à Deriva">
  <StarBackground />

  <main id="main-content" class="legal-page">
    <article class="legal-content">
      <p class="legal-kicker">&gt;_ user data</p>
      <h1>Data Deletion</h1>
      <p class="legal-updated">Last updated on April 26, 2026.</p>

      <section>
        <h2>How to request deletion</h2>
        <p>
          To request deletion of your data related to Devs à Deriva, send an email to
          <a href="mailto:leandrodukievicz1718@gmail.com">leandrodukievicz1718@gmail.com</a>
          with the subject "Data deletion".
        </p>
      </section>

      <section>
        <h2>What to include</h2>
        <p>
          Include the email or social account used to comment, the displayed name, and, when
          possible, the link to the post where the comment was submitted.
        </p>
      </section>

      <section>
        <h2>Processing time</h2>
        <p>
          After confirmation, the related data will be deleted or anonymized within 30 days, unless
          retention is required for legal, security, or abuse-prevention reasons.
        </p>
      </section>

      <section>
        <h2>Covered data</h2>
        <p>
          The request may include comments, name, email, profile image, and identifiers associated
          with the social login used to comment.
        </p>
      </section>
    </article>
  </main>
</Base>

<style>
  .legal-page {
    position: relative;
    z-index: 10;
    width: min(860px, calc(100% - 40px));
    margin: 0 auto;
    padding: 110px 0 80px;
  }

  .legal-content {
    color: var(--color-text);
  }

  .legal-kicker,
  .legal-updated {
    font-family: monospace;
    letter-spacing: 0.12em;
    color: var(--color-star);
  }

  .legal-kicker {
    margin: 0 0 16px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .legal-updated {
    margin: 18px 0 42px;
    font-size: 0.72rem;
    opacity: 0.58;
  }

  section {
    padding: 26px 0;
    border-top: 1px solid var(--color-star-12);
  }

  h2 {
    margin: 0 0 12px;
    font-family: monospace;
    font-size: 0.86rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  p {
    margin: 0 0 14px;
    max-width: 72ch;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    opacity: 0.78;
  }

  p:last-child {
    margin-bottom: 0;
  }

  a {
    color: var(--color-star);
    text-decoration: none;
    border-bottom: 1px solid var(--color-star-40);
  }

  a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>
